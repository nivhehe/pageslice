<!-- SpaceX-style fixed-width header -->
<header class="border border-neutral-800 bg-canvas/60 backdrop-blur-md p-6 rounded-2xl mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
  <div>
    <!-- Title using display font -->
    <div class="display-xl font-wise-sans font-black tracking-tight text-white flex items-center gap-3">
      <!-- Inline Brand Logo -->
      <a href="/" class="flex items-center gap-3 text-white hover:text-primary transition-all">
        <svg class="h-10 w-10 text-primary shrink-0" viewBox="0 0 128 128" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="128" height="128" rx="28" fill="#1c1d1a" stroke="#3a3a3f" stroke-width="2"/>
          <path d="M36 24h34l22 22v8L36 68V24z" fill="currentColor"/>
          <path d="M36 78l56-56v62H36V78z" fill="currentColor" opacity="0.4"/>
          <line x1="22" y1="84" x2="106" y2="16" stroke="currentColor" stroke-width="6" stroke-linecap="round"/>
          <circle cx="106" cy="16" r="4" fill="#ffffff"/>
        </svg>
        PAGESLICE
      </a>
      <span class="text-xs font-mono px-2 py-0.5 rounded border border-primary/30 bg-primary/10 text-primary uppercase tracking-widest">v1.3.0</span>
    </div>
    <p class="body-sm text-mute uppercase font-mono tracking-widest mt-1">
      ORBITAL PAGE INTERCEPT ENGINE
    </p>
  </div>
  
  <!-- Developer Support Contact -->
  <div class="text-xs font-mono text-mute border border-neutral-800 bg-canvas-soft/20 rounded-xl px-4 py-2 hover:border-primary/30 transition-all flex flex-col gap-1">
    <div>DEVELOPER: <a href="https://www.linkedin.com/in/nived-mohan-23170432b/" target="_blank" rel="noopener noreferrer" class="text-primary hover:text-primary-active underline">Nived Mohan</a></div>
  </div>
</header>

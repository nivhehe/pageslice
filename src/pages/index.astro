                <p class="text-xs text-mute font-inter leading-relaxed">Reorder any page visually in the grid to customize the output document sequence perfectly before extracting.</p>
              </div>
            </div>
          </div>

          <!-- On-Page SEO Information Deck -->
          <article class="border border-neutral-800 bg-canvas/40 backdrop-blur-md p-8 rounded-2xl mt-12 font-mono text-left max-w-none text-mute">

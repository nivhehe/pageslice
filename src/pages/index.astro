---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Free PDF Extractor Online - Split & Merge PDF Pages | PageSlice" description="Use the best free PDF extractor tool 2026 to split, delete, organize, or merge PDF pages, images, Word DOCX, and PowerPoint presentations 100% locally in your browser.">
  <!-- SpaceX-inspired dark container with custom grid backgrounds -->
  <main class="spacex-bg min-h-screen text-white relative overflow-hidden flex flex-col font-inter selection:bg-primary selection:text-on-primary">
    
    <!-- Telemetry System Toast / Notification Popup -->
    <div 
      id="telemetry-toast" 
      class="fixed top-6 left-1/2 -translate-x-1/2 z-50 flex items-center gap-3 border border-primary/30 bg-neutral-950/90 backdrop-blur-md px-6 py-4 rounded-2xl shadow-[0_0_30px_rgba(159,232,112,0.1)] transition-all duration-500 ease-out translate-y-[-150%] opacity-0 pointer-events-none font-mono text-xs uppercase tracking-wider text-white"
    >
      <div class="h-2 w-2 rounded-full bg-primary animate-pulse glow-primary"></div>
      <span>Tip: Drag pages to edit the order of pages</span>
      <button id="toast-close-btn" class="ml-2 text-mute hover:text-white transition-colors cursor-pointer" aria-label="Dismiss message">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Top Decorative Line -->
    <div class="h-1 bg-gradient-to-right from-primary/20 via-primary to-primary/20 w-full"></div>

    <div class="max-w-6xl w-full mx-auto px-4 py-8 sm:px-6 lg:px-8 flex-1 flex flex-col relative z-10">
      
      <Header />

      <!-- Central Content Hub -->
      <div class="flex-1 flex flex-col justify-center">

        <!-- Error Notification Banner -->
        <div id="error-banner" class="hidden border border-negative/50 bg-negative-bg/40 backdrop-blur-md rounded-2xl p-4 mb-6 flex items-center justify-between gap-4 animate-fade-in text-red-200">
          <div class="flex items-center gap-3">
            <svg class="h-5 w-5 text-negative shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <span id="error-message" class="text-sm font-mono uppercase tracking-wider">ERROR: INVALID DOCUMENT FORMAT</span>
          </div>
          <button id="close-error-btn" class="text-mute hover:text-white transition-colors" aria-label="Dismiss error">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <!-- STATE 1: File Dropzone (Default) -->
        <section id="dropzone-section" class="w-full">
          <div 
            id="dropzone" 
            class="border-2 border-dashed border-neutral-800 hover:border-primary/50 transition-all duration-300 rounded-2xl p-6 sm:p-12 text-center bg-canvas-soft/30 backdrop-blur-sm cursor-pointer flex flex-col items-center justify-center min-h-[250px] sm:min-h-[350px] group relative"
          >
            <!-- Grid Background Overlay inside dropzone -->
            <div class="absolute inset-0 spacex-grid opacity-30 rounded-2xl pointer-events-none"></div>

            <div class="relative z-10 flex flex-col items-center">
              <!-- Animated Rocket/Document SVG Icon -->
              <div class="h-16 w-16 mb-6 rounded-full bg-neutral-900 border border-neutral-800 flex items-center justify-center group-hover:border-primary/30 group-hover:scale-110 transition-all duration-300">
                <svg class="h-8 w-8 text-mute group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              </div>

              <h2 class="text-lg font-mono font-bold tracking-widest text-white uppercase mb-2">
                Drag & Drop Files
              </h2>
              <p class="body-sm text-mute mb-6">
                Supports multiple PDF, DOCX, PPTX, and Image (PNG, JPG) files. All files are processed locally.
              </p>

              <!-- Premium Pill Button (Wise + SpaceX styling) -->
              <button 
                id="browse-btn" 
                class="bg-primary text-on-primary hover:bg-primary-active active:scale-95 transition-all rounded-xl px-8 py-3 text-sm font-bold tracking-wider uppercase border border-primary/20 glow-primary hover:glow-primary-strong"
              >
                Browse Files
              </button>
              
              <input type="file" id="pdf-input" class="hidden" accept=".pdf,.docx,.pptx,.png,.jpg,.jpeg" multiple />
            </div>
          </div>

          <!-- Feature Advantages Grid (Sleek telemetry styling) -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-8 font-mono text-left">
            <div class="border border-neutral-800 bg-canvas/40 backdrop-blur-md p-5 rounded-2xl flex flex-col justify-between hover:border-primary/20 transition-all duration-300">
              <div>
                <span class="text-[10px] text-primary uppercase tracking-widest font-bold">SPEED SPEC</span>
                <h3 class="text-sm font-bold text-white uppercase mt-2 mb-1">Instant Processing</h3>
                <p class="text-xs text-mute font-inter leading-relaxed">No upload times. Multiple document compilation is done locally in your browser memory within milliseconds.</p>
              </div>
            </div>
            
            <div class="border border-neutral-800 bg-canvas/40 backdrop-blur-md p-5 rounded-2xl flex flex-col justify-between hover:border-primary/20 transition-all duration-300">
              <div>
                <span class="text-[10px] text-primary uppercase tracking-widest font-bold">ACCESS SPEC</span>
                <h3 class="text-sm font-bold text-white uppercase mt-2 mb-1">Zero Friction</h3>
                <p class="text-xs text-mute font-inter leading-relaxed">No login, registration, or emails required. Instant utility tools, ready when you are.</p>
              </div>
            </div>
            
            <div class="border border-neutral-800 bg-canvas/40 backdrop-blur-md p-5 rounded-2xl flex flex-col justify-between hover:border-primary/20 transition-all duration-300">
              <div>
                <span class="text-[10px] text-primary uppercase tracking-widest font-bold">COST SPEC</span>
                <h3 class="text-sm font-bold text-white uppercase mt-2 mb-1">100% Free & Private</h3>
                <p class="text-xs text-mute font-inter leading-relaxed">Zero subscription fees or usage caps. Client-side execution sandboxes files on your device.</p>
              </div>
            </div>

            <div class="border border-neutral-800 bg-canvas/40 backdrop-blur-md p-5 rounded-2xl flex flex-col justify-between hover:border-primary/20 transition-all duration-300">
              <div>
                <span class="text-[10px] text-primary uppercase tracking-widest font-bold">FORMAT SPEC</span>
                <h3 class="text-sm font-bold text-white uppercase mt-2 mb-1">Multi-Format support</h3>
                <p class="text-xs text-mute font-inter leading-relaxed">Combine PDFs, Word DOCX documents, PowerPoint PPTX presentations, and images simultaneously in one flow.</p>
              </div>
            </div>

            <div class="border border-neutral-800 bg-canvas/40 backdrop-blur-md p-5 rounded-2xl flex flex-col justify-between hover:border-primary/20 transition-all duration-300">
              <div>
                <span class="text-[10px] text-primary uppercase tracking-widest font-bold">WORKSPACE SPEC</span>
                <h3 class="text-sm font-bold text-white uppercase mt-2 mb-1">Incremental uploads</h3>
                <p class="text-xs text-mute font-inter leading-relaxed">Append additional documents or images at any time without losing your current selections or reordered list.</p>
              </div>
            </div>

            <div class="border border-neutral-800 bg-canvas/40 backdrop-blur-md p-5 rounded-2xl flex flex-col justify-between hover:border-primary/20 transition-all duration-300">
              <div>
                <span class="text-[10px] text-primary uppercase tracking-widest font-bold">ORDER SPEC</span>
                <h3 class="text-sm font-bold text-white uppercase mt-2 mb-1">Drag & Drop Arranger</h3>
                <p class="text-xs text-mute font-inter leading-relaxed">Reorder any page visually in the grid to customize the output document sequence perfectly before extracting.</p>
              </div>
            </div>
          </div>

          <!-- On-Page SEO Information Deck -->
          <article class="border border-neutral-800 bg-canvas/40 backdrop-blur-md p-8 rounded-2xl mt-12 font-mono text-left max-w-none text-mute">
            <header class="border-b border-neutral-800/50 pb-6 mb-6">
              <span class="text-[10px] text-primary uppercase tracking-widest font-bold">SYSTEM OVERVIEW</span>
              <h2 class="text-xl font-bold text-primary uppercase mt-2">PageSlice: The Ultimate Free PDF Extractor, Page Organizer & PDF Merger</h2>
              <p class="text-xs font-inter mt-3 leading-relaxed">
                Welcome to PageSlice, the premier, privacy-first <strong class="font-bold">free pdf extractor online</strong> that operates entirely within your browser. If you are looking for the <strong class="font-bold">best free pdf extractor tool 2026</strong> or a secure <strong class="font-bold">pdf page remover</strong> that runs 100% locally on your computer or mobile phone, PageSlice is designed for you. With page-level control and multi-format compatibility, PageSlice is the absolute <strong class="font-bold">best free pdf extractor tools 2026</strong> has to offer, eliminating the need to ever upload sensitive documents to third-party servers.
              </p>
            </header>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-xs font-inter leading-relaxed">
              <!-- Column 1 -->
              <div class="space-y-6">
                <div>
                  <h3 class="text-sm font-bold text-primary uppercase font-mono mb-2 tracking-wide">Powerful PDF Page Organizer & PDF Page Delete Capabilities</h3>
                  <p>
                    Managing complex PDF documents can be frustrating when you only need a few pages. PageSlice serves as an advanced <strong class="font-semibold">pdf page organizer</strong>, allowing you to visually inspect each page of your documents in real-time. Whether you need to split pages, rearrange them, or execute a <strong class="font-semibold">pdf page delete</strong> command, our interactive interface makes it simple. Just drop your file, choose the pages to keep, or use the tool as a <strong class="font-semibold">pdf page remover</strong> to delete unwanted sheets. Once satisfied, click "Extract" to generate a clean, optimized file instantly.
                  </p>
                </div>

                <div>
                  <h3 class="text-sm font-bold text-primary uppercase font-mono mb-2 tracking-wide">Local Conversion: Word, PowerPoint & Images to PDF</h3>
                  <p>
                    Beyond basic page extraction, PageSlice is an all-in-one <strong class="font-semibold">free pdf maker</strong> and format converter. It supports instant document transformation directly on your device:
                  </p>
                  <ul class="list-disc pl-5 mt-2 space-y-2">
                    <li><strong class="font-semibold">Photo to PDF Converter:</strong> Need to <strong class="font-semibold">convert photo to pdf</strong>? PageSlice is the fastest <strong class="font-semibold">photo to pdf</strong> processor online. It is fully responsive, answering the popular query of <strong class="font-semibold">how to convert photo to pdf on iphone</strong> or <strong class="font-semibold">how to convert a photo to pdf</strong> on any smartphone. Simply drop your PNG or JPG images, arrange them visually, and extract them as a single document.</li>
                    <li><strong class="font-semibold">Word Document to PDF:</strong> Easily learn <strong class="font-semibold">how to convert word document to pdf</strong> without Microsoft Office. Simply select your .docx files, and our system compiles them locally.</li>
                    <li><strong class="font-semibold">PPT to PDF Converter:</strong> Transform PowerPoint .pptx presentations into high-fidelity PDFs instantly using our integrated <strong class="font-semibold">ppt to pdf converter</strong>.</li>
                  </ul>
                </div>
              </div>

              <!-- Column 2 -->
              <div class="space-y-6">
                <div>
                  <h3 class="text-sm font-bold text-primary uppercase font-mono mb-2 tracking-wide">High-Performance Free PDF Merger</h3>
                  <p>
                    Need to merge multiple documents into one? Our built-in <strong class="font-semibold">free pdf merger</strong> is highly optimized. As a robust <strong class="font-semibold">online pdf merger</strong>, PageSlice allows you to append multiple files (PDFs, images, slides, and docs) in a single session. This <strong class="font-semibold">free online pdf merger</strong> lets you drag and drop pages from different source files to arrange them in any sequence. It is the easiest way to utilize a <strong class="font-semibold">pdf merger for free</strong> or perform a <strong class="font-semibold">pdf merger free</strong> operation on your files.
                  </p>
                </div>

                <div>
                  <h3 class="text-sm font-bold text-primary uppercase font-mono mb-2 tracking-wide">Best Free PDF Extractor Software Comparison: Online vs. Desktop Download</h3>
                  <p>
                    When choosing a tool to manage your files, you might consider a <strong class="font-semibold">free pdf extractor download</strong> or dedicated offline <strong class="font-semibold">free pdf extractor software</strong>. Here is a quick <strong class="font-semibold">best free pdf extractor software comparison</strong> to show why PageSlice is the superior choice:
                  </p>
                  <ol class="list-decimal pl-5 mt-2 space-y-2">
                    <li><strong class="font-semibold">Privacy & Security:</strong> Traditional software download and server-side web platforms risk exposing your documents. PageSlice processes all files inside your web browser using HTML5 features—your files never leave your device.</li>
                    <li><strong class="font-semibold">Speed & Accessibility:</strong> No installation, sign-ups, or subscriptions. It runs on Mac, Windows, iOS, and Android, making it the <strong class="font-semibold">best free pdf extractor tool 2025 2026</strong> for zero-friction workflows.</li>
                    <li><strong class="font-semibold">Multi-Format Versatility:</strong> Most basic software only splits PDFs. PageSlice merges, deletes pages, and converts Word docs, PowerPoints, and images simultaneously.</li>
                  </ol>
                </div>
              </div>
            </div>

            <footer class="border-t border-neutral-800/50 mt-8 pt-6 grid grid-cols-1 sm:grid-cols-3 gap-6 text-[11px]">
              <div>
                <h4 class="font-bold text-primary uppercase font-mono mb-1">How to Convert Photo to PDF on iPhone</h4>
                <p class="font-inter leading-relaxed">Open PageSlice in Safari or Chrome, tap "Browse Files", select images from the gallery, arrange the order, and click "Extract".</p>
              </div>
              <div>
                <h4 class="font-bold text-primary uppercase font-mono mb-1">How to Convert Word Document to PDF</h4>
                <p class="font-inter leading-relaxed">Select your DOCX file, wait for local conversion to finish in your browser memory, and download the compiled file.</p>
              </div>
              <div>
                <h4 class="font-bold text-primary uppercase font-mono mb-1">How to Delete PDF Pages</h4>
                <p class="font-inter leading-relaxed">Drag your PDF, select only the pages you want to keep (effectively deleting the unselected ones), and click the extract button.</p>
              </div>
            </footer>
          </article>

          <!-- On-Page SEO FAQ Accordion/Deck -->
          <section class="border border-neutral-800 bg-canvas/40 backdrop-blur-md p-8 rounded-2xl mt-8 font-mono text-left max-w-none">
            <header class="border-b border-neutral-800/50 pb-6 mb-6">
              <span class="text-[10px] text-primary uppercase tracking-widest font-bold">SUPPORT / FAQS</span>
              <h2 class="text-xl font-bold text-primary uppercase mt-2">Frequently Asked Questions</h2>
              <p class="text-xs text-mute font-inter mt-1 leading-relaxed">
                Everything you need to know about extracting pages, merging files, and document privacy.
              </p>
            </header>

            <div class="space-y-6 text-xs">
              <div class="border-b border-neutral-800/50 pb-6 text-left">
                <h3 class="text-sm font-bold text-white uppercase tracking-wide mb-2"><span class="text-primary font-bold">Q /</span> How can I remove pages from a PDF?</h3>
                <p class="text-mute font-inter leading-relaxed">PageSlice makes removing pages from a PDF simple. Drag and drop your PDF file onto the page, check only the pages you want to keep, and then click the "Extract Selected Pages" button. The unchecked pages will be removed, creating a new PDF instantly on your device.</p>
              </div>

              <div class="border-b border-neutral-800/50 pb-6 text-left">
                <h3 class="text-sm font-bold text-white uppercase tracking-wide mb-2"><span class="text-primary font-bold">Q /</span> Can I delete pages from a PDF?</h3>
                <p class="text-mute font-inter leading-relaxed">Yes, you can easily delete pages from any PDF document. Simply load the PDF into PageSlice, select the pages you want to keep, and compile the new document. The unselected pages are effectively deleted.</p>
              </div>

              <div class="border-b border-neutral-800/50 pb-6 text-left">
                <h3 class="text-sm font-bold text-white uppercase tracking-wide mb-2"><span class="text-primary font-bold">Q /</span> Is this Extract PDF tool free to use?</h3>
                <p class="text-mute font-inter leading-relaxed">Yes! PageSlice is a 100% free online PDF maker and extractor. There are no subscriptions, registration requirements, file limits, or watermarks.</p>
              </div>

              <div class="border-b border-neutral-800/50 pb-6 text-left">
                <h3 class="text-sm font-bold text-white uppercase tracking-wide mb-2"><span class="text-primary font-bold">Q /</span> How to extract multiple pages from PDF?</h3>
                <p class="text-mute font-inter leading-relaxed">To extract multiple pages, upload your PDF to PageSlice. You can select specific pages manually by clicking on their thumbnails, enter a page range (e.g., "1, 3, 5-8") in the Range Input box, or search for text content. When done, click "Extract Selected Pages".</p>
              </div>

              <div class="border-b border-neutral-800/50 pb-6 text-left">
                <h3 class="text-sm font-bold text-white uppercase tracking-wide mb-2"><span class="text-primary font-bold">Q /</span> Can I extract specific pages from a scanned PDF document?</h3>
                <p class="text-mute font-inter leading-relaxed">Yes. PageSlice loads and processes scanned PDF documents locally in your browser, allowing you to select and extract any specific page.</p>
              </div>

              <div class="border-b border-neutral-800/50 pb-6 text-left">
                <h3 class="text-sm font-bold text-white uppercase tracking-wide mb-2"><span class="text-primary font-bold">Q /</span> How many PDF pages can I extract?</h3>
                <p class="text-mute font-inter leading-relaxed">There are no page extraction limits. Since PageSlice works entirely client-side using your browser memory, you can extract as many pages as your computer or device can process.</p>
              </div>

              <div class="border-b border-neutral-800/50 pb-6 text-left">
                <h3 class="text-sm font-bold text-white uppercase tracking-wide mb-2"><span class="text-primary font-bold">Q /</span> Is it possible to extract pages from a PDF and save them as a new file?</h3>
                <p class="text-mute font-inter leading-relaxed">Yes. When you click "Extract Selected Pages", PageSlice generates a new, separate PDF file in your browser memory and triggers an automatic download, saving the extracted pages as a new file.</p>
              </div>

              <div class="border-b border-neutral-800/50 pb-6 text-left">
                <h3 class="text-sm font-bold text-white uppercase tracking-wide mb-2"><span class="text-primary font-bold">Q /</span> Is my data safe and private when using the Extract PDF tool?</h3>
                <p class="text-mute font-inter leading-relaxed">Absolutely. PageSlice is a privacy-first, client-side tool. Your documents are never uploaded to any server. All processing, decryption, conversion, and compilation occur locally on your machine.</p>
              </div>

              <div class="border-b border-neutral-800/50 pb-6 text-left">
                <h3 class="text-sm font-bold text-white uppercase tracking-wide mb-2"><span class="text-primary font-bold">Q /</span> How do I separate pages from a PDF?</h3>
                <p class="text-mute font-inter leading-relaxed">Upload your PDF to PageSlice, choose the pages you wish to split or keep, and compile them. You can also add more files to merge them or rearrange their order.</p>
              </div>

              <div class="border-b border-neutral-800/50 pb-6 text-left">
                <h3 class="text-sm font-bold text-white uppercase tracking-wide mb-2"><span class="text-primary font-bold">Q /</span> How to merge PDF files?</h3>
                <p class="text-mute font-inter leading-relaxed">To merge PDF files, drag and drop multiple PDF documents onto the PageSlice upload box. You can then drag to rearrange pages from different files into your desired order, select all of them, and click "Extract Selected Pages" to merge them into a single file.</p>
              </div>

              <div class="border-b border-neutral-800/50 pb-6 text-left">
                <h3 class="text-sm font-bold text-white uppercase tracking-wide mb-2"><span class="text-primary font-bold">Q /</span> How can I merge PDFs offline?</h3>
                <p class="text-mute font-inter leading-relaxed">PageSlice is designed to work client-side. Once the page is loaded in your browser, the document processing code runs offline. Your files never leave your computer, allowing you to merge PDFs without an internet connection.</p>
              </div>

              <div class="border-b border-neutral-800/50 pb-6 text-left">
                <h3 class="text-sm font-bold text-white uppercase tracking-wide mb-2"><span class="text-primary font-bold">Q /</span> How can I merge PDF files on a Mac?</h3>
                <p class="text-mute font-inter leading-relaxed">Open PageSlice in any web browser on your Mac, drag and drop the PDF files you want to combine, arrange the pages, and click "Extract Selected Pages" to save the merged document.</p>
              </div>

              <div class="border-b border-neutral-800/50 pb-6 text-left">
                <h3 class="text-sm font-bold text-white uppercase tracking-wide mb-2"><span class="text-primary font-bold">Q /</span> Can I merge PDFs on mobile devices?</h3>
                <p class="text-mute font-inter leading-relaxed">Yes! PageSlice is fully responsive. You can open PageSlice in your mobile browser (such as Safari on iOS or Chrome on Android) and upload, arrange, and merge PDFs directly on your phone or tablet.</p>
              </div>

              <div class="border-b border-neutral-800/50 pb-6 text-left">
                <h3 class="text-sm font-bold text-white uppercase tracking-wide mb-2"><span class="text-primary font-bold">Q /</span> How to merge multiple Word documents?</h3>
                <p class="text-mute font-inter leading-relaxed">PageSlice supports DOCX files. Drag and drop multiple Word documents onto the page. They will be converted to PDF locally in your browser, allowing you to select, reorder, and merge pages from them into a single PDF.</p>
              </div>

              <div class="pb-2 text-left">
                <h3 class="text-sm font-bold text-white uppercase tracking-wide mb-2"><span class="text-primary font-bold">Q /</span> Is it possible to merge PDF and JPG files together?</h3>
                <p class="text-mute font-inter leading-relaxed">Yes! PageSlice lets you merge different formats simultaneously. You can upload PDFs, JPG/PNG images, Word documents, and PowerPoint slides in one session, arrange their pages in any order, and merge them into one PDF.</p>
              </div>
            </div>
          </section>

          <!-- Schema JSON-LD for FAQ Page -->

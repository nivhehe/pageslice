<script>
  // Import PDF-Lib library compiled client-side by Vite
  import { PDFDocument, StandardFonts } from 'pdf-lib';

  // Virtual Page layout interface
  interface VirtualPage {
    id: string; // unique page identification key
    fileIndex: number;
    pageIndex: number;
    fileName: string;
    text: string;
  }

  // State
  let loadedFiles: File[] = [];
  let loadedPdfDocs: any[] = [];
  let loadedPdfJsDocs: any[] = [];
  let virtualPages: VirtualPage[] = [];
  let pageOrder: number[] = [];
  let selectedPages = new Set<string>();

  // Decryption state tracking
  let pendingFilesList: File[] | null = null;
  let pendingFileIndex = 0;
  let pendingFile: File | null = null;
  let filePasswords: { [key: number]: string } = {};
  let pendingIsAppend = false;

  // Element Selectors
  const dropzone = document.getElementById('dropzone') as HTMLElement;
  const pdfInput = document.getElementById('pdf-input') as HTMLInputElement;
  const browseBtn = document.getElementById('browse-btn') as HTMLButtonElement;
  const dropzoneSection = document.getElementById('dropzone-section') as HTMLElement;
  const dashboardSection = document.getElementById('dashboard-section') as HTMLElement;
  const errorBanner = document.getElementById('error-banner') as HTMLElement;
  const errorMessage = document.getElementById('error-message') as HTMLElement;
  const closeErrorBtn = document.getElementById('close-error-btn') as HTMLButtonElement;
  
  // Metadata Panel Selectors
  const metaFilename = document.getElementById('metadata-filename') as HTMLElement;
  const metaFilesize = document.getElementById('metadata-filesize') as HTMLElement;
  const metaTotalPages = document.getElementById('metadata-total-pages') as HTMLElement;

  // Grid and Controls
  const pagesGrid = document.getElementById('pages-grid') as HTMLElement;
  const selectAllBtn = document.getElementById('select-all-btn') as HTMLButtonElement;
  const clearSelectionBtn = document.getElementById('clear-selection-btn') as HTMLButtonElement;
  const invertSelectionBtn = document.getElementById('invert-selection-btn') as HTMLButtonElement;
  const rangeInput = document.getElementById('range-input') as HTMLInputElement;
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchSelectBtn = document.getElementById('search-select-btn') as HTMLButtonElement;
  const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;
  const addFilesBtn = document.getElementById('add-files-btn') as HTMLButtonElement;
  const addFilesInput = document.getElementById('add-files-input') as HTMLInputElement;

  // Decryption Overlay Elements
  const decryptModal = document.getElementById('decrypt-modal') as HTMLElement;
  const decryptFilename = document.getElementById('decrypt-filename') as HTMLElement;
  const decryptPasswordInput = document.getElementById('decrypt-password-input') as HTMLInputElement;
  const decryptError = document.getElementById('decrypt-error') as HTMLElement;
  const decryptCancelBtn = document.getElementById('decrypt-cancel-btn') as HTMLButtonElement;
  const decryptSubmitBtn = document.getElementById('decrypt-submit-btn') as HTMLButtonElement;

  // Sticky Action Footer
  const stickyFooter = document.getElementById('sticky-footer') as HTMLElement;
  const selectedCountLabel = document.getElementById('selected-count-label') as HTMLElement;
  const extractBtn = document.getElementById('extract-btn') as HTMLButtonElement;
  const compilingLoader = document.getElementById('compiling-loader') as HTMLElement;

  // Initialize
  setupEventListeners();

  function setupEventListeners() {
    // File inputs
    browseBtn.addEventListener('click', () => pdfInput.click());
    pdfInput.addEventListener('change', handleFileSelect);

    // Error banner close
    closeErrorBtn.addEventListener('click', hideError);

    // Drag-and-drop actions
    ['dragenter', 'dragover'].forEach(eventName => {
      dropzone.addEventListener(eventName, highlight, false);
    });

    ['dragleave', 'drop'].forEach(eventName => {
      dropzone.addEventListener(eventName, unhighlight, false);
    });

    dropzone.addEventListener('drop', handleDrop, false);

    // Selection buttons
    selectAllBtn.addEventListener('click', selectAll);
    clearSelectionBtn.addEventListener('click', clearSelection);
    invertSelectionBtn.addEventListener('click', invertSelection);

    // Inputs
    rangeInput.addEventListener('input', handleRangeInput);
    searchInput.addEventListener('input', handleSearchInput);

    // Add Files flow
    addFilesBtn.addEventListener('click', () => addFilesInput.click());
    addFilesInput.addEventListener('change', handleAddFilesSelect);

    // Dashboard drag and drop files to append
    dashboardSection.addEventListener('dragover', (e) => {
      if (e.dataTransfer && e.dataTransfer.types.includes('Files')) {
        e.preventDefault();
        dashboardSection.classList.add('border-primary/30', 'bg-primary/5');
      }
    });

    dashboardSection.addEventListener('dragleave', () => {
      dashboardSection.classList.remove('border-primary/30', 'bg-primary/5');
    });

    dashboardSection.addEventListener('drop', (e) => {
      if (e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files.length > 0) {
        e.preventDefault();
        dashboardSection.classList.remove('border-primary/30', 'bg-primary/5');
        processFiles(e.dataTransfer.files, true);
      }
    });

    // Reset flow
    resetBtn.addEventListener('click', resetApp);

    // PDF Compile Execution
    extractBtn.addEventListener('click', executeExtraction);

    // Decryption Dialog submissions
    decryptSubmitBtn.addEventListener('click', submitPassword);
    decryptPasswordInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') submitPassword();
    });
    decryptCancelBtn.addEventListener('click', abortDecryption);
  }

  // File Drag-Drop Event Helpers
  function highlight(e: DragEvent) {
    e.preventDefault();
    e.stopPropagation();
    dropzone.classList.add('border-primary/60', 'scale-[1.01]', 'bg-canvas-soft/55');
  }

  function unhighlight(e: DragEvent) {
    e.preventDefault();
    e.stopPropagation();
    dropzone.classList.remove('border-primary/60', 'scale-[1.01]', 'bg-canvas-soft/55');
  }

  function handleDrop(e: DragEvent) {
    const dt = e.dataTransfer;
    if (dt && dt.files && dt.files.length > 0) {
      processFiles(dt.files);
    }
  }

  function handleFileSelect(e: Event) {
    const target = e.target as HTMLInputElement;
    if (target.files && target.files.length > 0) {
      processFiles(target.files, false);
    }
  }

  function handleAddFilesSelect(e: Event) {
    const target = e.target as HTMLInputElement;
    if (target.files && target.files.length > 0) {
      processFiles(target.files, true);
    }
  }

  // DOCX to PDF converter client-side using XML parsing via JSZip
  async function convertDocxToPdf(arrayBuffer: ArrayBuffer): Promise<ArrayBuffer> {
    // @ts-ignore
    const JSZip = window.JSZip;
    const zip = await JSZip.loadAsync(arrayBuffer);
    const docXml = await zip.file("word/document.xml").async("string");
    
    const parser = new DOMParser();
    const xmlDoc = parser.parseFromString(docXml, "text/xml");
    const paragraphs = xmlDoc.getElementsByTagName("w:p");
    
    const lines: string[] = [];
    for (let i = 0; i < paragraphs.length; i++) {
      const p = paragraphs[i];
      const text = p.textContent || '';
      
      const words = text.split(/\s+/);
      let currentLine = '';
      for (const word of words) {
        if ((currentLine + ' ' + word).length > 75) {
          lines.push(currentLine.trim());
          currentLine = word;
        } else {
          currentLine = currentLine ? currentLine + ' ' + word : word;
        }
      }
      if (currentLine) {
        lines.push(currentLine.trim());
      }
      lines.push('');
    }

    const newPdfDoc = await PDFDocument.create();
    const font = await newPdfDoc.embedFont(StandardFonts.Helvetica);
    const linesPerPage = 35;
    const pageCount = Math.ceil(lines.length / linesPerPage) || 1;

    for (let p = 0; p < pageCount; p++) {
      const page = newPdfDoc.addPage([612, 792]);
      const startIndex = p * linesPerPage;
      const pageLines = lines.slice(startIndex, startIndex + linesPerPage);
      
      pageLines.forEach((line, index) => {
        if (!line.trim()) return;
        page.drawText(line, {
          x: 50,
          y: 730 - index * 18,
          size: 10.5,
          font: font,
          color: { type: 'RGB', red: 0.08, green: 0.09, blue: 0.08 }
        });
      });
    }

    return await newPdfDoc.save();
  }

  // PPTX to PDF converter client-side using slides XML parsing via JSZip
  async function convertPptxToPdf(arrayBuffer: ArrayBuffer): Promise<ArrayBuffer> {
    // @ts-ignore
    const JSZip = window.JSZip;
    const zip = await JSZip.loadAsync(arrayBuffer);
    
    const slideFiles = Object.keys(zip.files).filter(name => name.startsWith("ppt/slides/slide") && name.endsWith(".xml"));
    slideFiles.sort((a, b) => {
      const numA = parseInt(a.replace(/[^0-9]/g, ""), 10);
      const numB = parseInt(b.replace(/[^0-9]/g, ""), 10);
      return numA - numB;
    });

    const newPdfDoc = await PDFDocument.create();
    const font = await newPdfDoc.embedFont(StandardFonts.Helvetica);

    if (slideFiles.length === 0) {
      const page = newPdfDoc.addPage([792, 612]);
      page.drawText("EMPTY PRESENTATION SLIDES", { x: 100, y: 300, size: 24, font });
    }

    for (const slideFile of slideFiles) {
      const slideXml = await zip.file(slideFile).async("string");
      const parser = new DOMParser();
      const xmlDoc = parser.parseFromString(slideXml, "text/xml");
      
      const textElements = xmlDoc.getElementsByTagName("a:t");
      let slideText = "";
      for (let i = 0; i < textElements.length; i++) {
        slideText += textElements[i].textContent + " ";
      }

      const page = newPdfDoc.addPage([792, 612]);
      page.drawRectangle({
        x: 20,
        y: 20,
        width: 752,
        height: 572,
        borderWidth: 1,
        borderColor: { type: 'RGB', red: 0.85, green: 0.85, blue: 0.85 },
        color: { type: 'RGB', red: 0.98, green: 0.98, blue: 0.98 }
      });

      const words = slideText.trim().split(/\s+/);
      const lines: string[] = [];
      let currentLine = '';
      for (const word of words) {
        if ((currentLine + ' ' + word).length > 90) {
          lines.push(currentLine.trim());
          currentLine = word;
        } else {
          currentLine = currentLine ? currentLine + ' ' + word : word;
        }
      }
      if (currentLine) {
        lines.push(currentLine.trim());
      }

      lines.slice(0, 22).forEach((line, index) => {
        page.drawText(line, {
          x: 50,
          y: 530 - index * 22,
          size: 12.5,
          font: font,
          color: { type: 'RGB', red: 0.1, green: 0.1, blue: 0.1 }
        });
      });
    }

    return await newPdfDoc.save();
  }

  // Image to PDF compilation client-side
  async function convertImageToPdf(arrayBuffer: ArrayBuffer, fileName: string): Promise<ArrayBuffer> {
    const newPdfDoc = await PDFDocument.create();
    let image;
    
    if (fileName.toLowerCase().endsWith('.png')) {
      image = await newPdfDoc.embedPng(arrayBuffer);
    } else {
      image = await newPdfDoc.embedJpg(arrayBuffer);
    }

    const { width, height } = image.scale(0.8);
    const page = newPdfDoc.addPage([width, height]);
    
    page.drawImage(image, {
      x: 0,
      y: 0,
      width,
      height
    });

    return await newPdfDoc.save();
  }

  // Core Processing Flow for Multiple Files
  async function processFiles(files: FileList | File[], append = false) {
    // Show temporary spinner in button
    const activeBtn = append ? addFilesBtn : browseBtn;
    if (activeBtn) {
      activeBtn.textContent = 'LOADING…';
      activeBtn.disabled = true;
    }
    hideError();

    if (!append) {
      // Reset states
      loadedFiles = [];
      loadedPdfDocs = [];
      loadedPdfJsDocs = [];
      virtualPages = [];
      pageOrder = [];
      selectedPages.clear();
      filePasswords = {};
    }

    const newFilesArray = Array.from(files);
    const startIndex = loadedFiles.length;
    
    // Add to loaded files list
    if (append) {
      loadedFiles = [...loadedFiles, ...newFilesArray];
    } else {
      loadedFiles = newFilesArray;
    }

    let totalBytes = loadedFiles.reduce((acc, f) => acc + f.size, 0);

    try {
      // Process new files sequentially
      for (let i = 0; i < newFilesArray.length; i++) {
        const file = newFilesArray[i];
        const f = startIndex + i; // absolute file index
        
        if (!/\.(pdf|docx|pptx|png|jpe?g)$/i.test(file.name)) {
          showError(`FILE FORMAT ERROR: "${file.name}" is not supported. Use PDF, DOCX, PPTX, or Images.`);
          return;
        }

        let arrayBuffer = await file.arrayBuffer();

        // Perform client-side conversions if not PDF
        if (file.name.toLowerCase().endsWith('.docx')) {
          arrayBuffer = await convertDocxToPdf(arrayBuffer);
        } else if (file.name.toLowerCase().endsWith('.pptx')) {
          arrayBuffer = await convertPptxToPdf(arrayBuffer);
        } else if (/\.(png|jpe?g)$/i.test(file.name)) {
          arrayBuffer = await convertImageToPdf(arrayBuffer, file.name);
        }

        // Load PDF via pdf-lib for compilation (slice buffer to avoid detachment)
        const libBuffer = arrayBuffer.slice(0);
        const filePassword = filePasswords[f] || '';
        let pdfLibDoc;
        try {
          pdfLibDoc = await PDFDocument.load(libBuffer, { 
            updateMetadata: false,
            password: filePassword
          });
        } catch (libErr: any) {
          if (libErr.message.includes('Password') || libErr.message.includes('encrypted') || libErr.message.includes('decrypt')) {
            showDecryptionPromptForFile(file, newFilesArray, f, append);
            return;
          }
          throw libErr;
        }

        const filePagesCount = pdfLibDoc.getPageCount();
        if (filePagesCount === 0) continue;

        // Load PDF via PDF.js for rendering thumbnails
        // @ts-ignore
        const pdfjsLib = window.pdfjsLib;
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
        const jsDocBuffer = arrayBuffer.slice(0);
        
        let pdfJsDoc;
        try {
          const loadingTask = pdfjsLib.getDocument({ 
            data: jsDocBuffer,
            password: filePassword
          });
          pdfJsDoc = await loadingTask.promise;
        } catch (jsErr: any) {
          if (jsErr.name === 'PasswordException') {
            showDecryptionPromptForFile(file, newFilesArray, f, append);
            return;
          }
          throw jsErr;
        }

        loadedPdfDocs[f] = pdfLibDoc;
        loadedPdfJsDocs[f] = pdfJsDoc;

        // Extract text and build VirtualPage metadata
        const oldVirtualPagesLength = virtualPages.length;
        const newVirtualPages: VirtualPage[] = [];
        for (let p = 0; p < filePagesCount; p++) {
          let textStr = '';
          try {
            const page = await pdfJsDoc.getPage(p + 1);
            const textObj = await page.getTextContent();
            textStr = textObj.items.map((item: any) => item.str).join(' ');
          } catch (err) {
            console.error(`Error extracting page text:`, err);
          }

          const pageId = `${f}-${p}`;
          newVirtualPages.push({
            id: pageId,
            fileIndex: f,
            pageIndex: p,
            fileName: file.name,
            text: textStr.toLowerCase()
          });
        }

        virtualPages = [...virtualPages, ...newVirtualPages];
        
        // Append new page indices to the visual order
        const newPageIndices = Array.from(
          { length: newVirtualPages.length }, 
          (_, idx) => oldVirtualPagesLength + idx
        );
        pageOrder = [...pageOrder, ...newPageIndices];
      }

      const totalVirtualPages = virtualPages.length;
      if (totalVirtualPages === 0) {
        throw new Error('No pages found in uploaded files.');
      }

      // Update Metadata readout UI
      let activeFileNameText = '';
      if (loadedFiles.length === 1) {
        activeFileNameText = loadedFiles[0].name.toUpperCase();
      } else {
        const firstFileBase = loadedFiles[0].name.replace(/\.[^/.]+$/, "").toUpperCase();
        activeFileNameText = `${firstFileBase} + ${loadedFiles.length - 1} OTHER FILE${loadedFiles.length > 2 ? 'S' : ''}`;
      }

      metaFilename.textContent = activeFileNameText;
      metaFilesize.textContent = formatBytes(totalBytes);
      metaTotalPages.textContent = `${totalVirtualPages} Page${totalVirtualPages > 1 ? 's' : ''}`;

      // Reset control fields if not appending
      if (!append) {
        rangeInput.value = '';
        searchInput.value = '';
        searchSelectBtn.classList.add('hidden');
      }

      // Populate interactive grid
      renderPagesGrid();
      updateStickyFooter();

      // View Transitions / Show dashboard
      dropzoneSection.classList.add('hidden');
      dashboardSection.classList.remove('hidden');
    } catch (err) {
      console.error(err);
      showError('PARSING ERROR: Unable to read file data locally. Document may be encrypted or corrupted.');
      resetState();
    } finally {
      if (activeBtn) {
        activeBtn.textContent = append ? 'Add Files' : 'Browse Files';
        activeBtn.disabled = false;
      }
    }
  }

  function renderPagesGrid() {
    pagesGrid.innerHTML = '';
    
    pageOrder.forEach((virtualIndex, visualIndex) => {
      const vp = virtualPages[virtualIndex];
      const card = document.createElement('div');
      
      // Tailwind CSS Classes for the technical SpaceX page card
      card.className = `group aspect-[3/4] relative bg-canvas-soft/20 hover:bg-canvas-soft border border-neutral-800 hover:border-neutral-700 hover:scale-[1.02] cursor-pointer rounded-xl overflow-hidden transition-all duration-300 select-none flex flex-col p-3`;
      card.setAttribute('data-page-index', virtualIndex.toString());
      card.setAttribute('data-visual-index', visualIndex.toString());
      card.id = `page-card-${vp.id}`;
      card.draggable = true;

      // Card layout: show visual index, original index, and the file name it belongs to
      card.innerHTML = `
        <!-- Drag Handle / Dot icon in top-left -->
        <div class="absolute top-2.5 left-2.5 w-5 h-5 rounded-full border border-neutral-800/60 flex items-center justify-center bg-canvas/30 transition-all card-drag-handle opacity-0 group-hover:opacity-100 cursor-grab active:cursor-grabbing z-20">
          <svg class="h-3 w-3 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </div>

        <!-- Selection checkmark indicator -->
        <div class="absolute top-2.5 right-2.5 w-5 h-5 rounded-full border border-neutral-800 flex items-center justify-center bg-canvas-soft/80 transition-all card-check-badge z-20">
          <svg class="h-3 w-3 text-on-primary hidden check-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>

        <!-- Render Canvas Container (actual preview canvas) -->
        <div class="flex-1 w-full aspect-[3/4] overflow-hidden rounded bg-neutral-950 flex items-center justify-center border border-neutral-900 relative">
          <canvas id="canvas-page-${vp.id}" class="max-w-full max-h-full object-contain pointer-events-none transition-all duration-300 group-hover:scale-[1.03]"></canvas>
          <div id="loader-page-${vp.id}" class="absolute inset-0 flex items-center justify-center bg-neutral-950 font-mono text-[9px] text-mute animate-pulse uppercase">RENDER…</div>
        </div>

        <!-- Divider line -->
        <div class="h-[1px] bg-neutral-800/80 my-2.5"></div>

        <!-- Monospace index footer containing multi-file references -->
        <div class="flex flex-col gap-0.5 text-left">
          <div class="text-[8px] font-mono text-primary truncate max-w-full uppercase tracking-wider" title="${vp.fileName}">
            ${vp.fileName}
          </div>
          <div class="flex justify-between items-center text-[10px] font-mono text-mute mt-auto">
            <span>PAGE ${String(vp.pageIndex + 1).padStart(2, '0')}</span>
            <span class="text-[9px] opacity-0 group-hover:opacity-100 transition-opacity text-primary">DRAG</span>
          </div>
        </div>
      `;

      // Click card selects it (unless drag handle is targeted)
      card.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('.card-drag-handle')) return;
        togglePageSelection(vp.id);
      });

      // Hook up native HTML5 Drag and Drop event listeners
      setupDragEvents(card, virtualIndex);
      
      pagesGrid.appendChild(card);

      // Re-sync visual selections
      setCardSelectedVisual(vp.id, selectedPages.has(vp.id));

      // Async render call using the correct pdfJsDoc object for this virtual page
      renderPageThumbnail(loadedPdfJsDocs[vp.fileIndex], vp.pageIndex, vp.id);
    });
  }

  // HTML5 Drag-and-drop mechanics
  let draggedIndex: number | null = null;

  function setupDragEvents(card: HTMLElement, virtualIndex: number) {
    card.addEventListener('dragstart', (e) => {
      draggedIndex = virtualIndex;
      card.classList.add('opacity-50', 'scale-95', 'border-primary/50');
      if (e.dataTransfer) {
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', virtualIndex.toString());
      }
    });

    card.addEventListener('dragend', () => {
      card.classList.remove('opacity-50', 'scale-95', 'border-primary/50');
      
      // Clean up drop outlines across cards
      const allCards = pagesGrid.querySelectorAll('[id^="page-card-"]');
      allCards.forEach(c => c.classList.remove('border-primary'));
    });

    card.addEventListener('dragover', (e) => {
      e.preventDefault();
      if (draggedIndex === null || draggedIndex === virtualIndex) return;

      if (e.dataTransfer) {
        e.dataTransfer.dropEffect = 'move';
      }
      card.classList.add('border-primary/50');
    });

    card.addEventListener('dragleave', () => {
      if (draggedIndex === null || draggedIndex === virtualIndex) return;
      card.classList.remove('border-primary/50');
    });

    card.addEventListener('drop', (e) => {
      e.preventDefault();
      card.classList.remove('border-primary/50');
      
      if (draggedIndex === null || draggedIndex === virtualIndex) return;

      const fromIndex = pageOrder.indexOf(draggedIndex);
      const toIndex = pageOrder.indexOf(virtualIndex);

      if (fromIndex !== -1 && toIndex !== -1) {
        // Swap indices sequences
        pageOrder.splice(fromIndex, 1);
        pageOrder.splice(toIndex, 0, draggedIndex);

        // Re-draw grid to visually map new order sequence
        renderPagesGrid();
      }
    });
  }

  async function renderPageThumbnail(pdfJsDoc: any, pageIndex: number, pageId: string) {
    try {
      const page = await pdfJsDoc.getPage(pageIndex + 1);
      const canvas = document.getElementById(`canvas-page-${pageId}`) as HTMLCanvasElement;
      if (!canvas) return;

      const context = canvas.getContext('2d');
      if (!context) return;

      // Adjust scale to a standard thumbnail width (180px)
      const desiredWidth = 180;
      const originalViewport = page.getViewport({ scale: 1 });
      const scale = desiredWidth / originalViewport.width;
      const viewport = page.getViewport({ scale });

      canvas.width = viewport.width;
      canvas.height = viewport.height;

      const renderContext = {
        canvasContext: context,
        viewport: viewport
      };

      await page.render(renderContext).promise;

      // Hide loader
      const loader = document.getElementById(`loader-page-${pageId}`);
      if (loader) loader.classList.add('hidden');
    } catch (err) {
      console.error(`Error rendering page thumbnail ${pageId}:`, err);
      const loader = document.getElementById(`loader-page-${pageId}`);
      if (loader) loader.textContent = 'ERROR';
    }
  }

  // Decryption Prompt Modal Helpers
  function showDecryptionPromptForFile(file: File, files: File[], index: number, append = false) {
    pendingFile = file;
    pendingFilesList = files;
    pendingFileIndex = index;
    pendingIsAppend = append;
    
    decryptFilename.textContent = file.name;
    decryptPasswordInput.value = '';
    decryptError.classList.add('hidden');
    decryptModal.classList.remove('hidden');
    decryptPasswordInput.focus();

    // Reset browse button state
    const activeBtn = append ? addFilesBtn : browseBtn;
    if (activeBtn) {
      activeBtn.textContent = append ? 'Add Files' : 'Browse Files';
      activeBtn.disabled = false;
    }
  }

  function hideDecryptionPrompt() {
    decryptModal.classList.add('hidden');
    pendingFile = null;
    pendingFilesList = null;
  }

  function submitPassword() {
    const password = decryptPasswordInput.value;
    if (pendingFile && pendingFilesList) {
      decryptError.classList.add('hidden');
      filePasswords[pendingFileIndex] = password;
      
      if (pendingIsAppend) {
        const countBeforeAppend = pendingFileIndex - pendingFilesList.indexOf(pendingFile);
        loadedFiles = loadedFiles.slice(0, countBeforeAppend);
      }
      
      processFiles(pendingFilesList, pendingIsAppend);
    }
  }

  function abortDecryption() {
    hideDecryptionPrompt();
    resetState();
    pdfInput.value = '';
    addFilesInput.value = '';
  }

  function togglePageSelection(pageId: string) {
    if (selectedPages.has(pageId)) {
      selectedPages.delete(pageId);
      setCardSelectedVisual(pageId, false);
    } else {
      selectedPages.add(pageId);
      setCardSelectedVisual(pageId, true);
    }
    
    // De-synchronize range input
    rangeInput.value = '';
    updateStickyFooter();
  }

  function setCardSelectedVisual(pageId: string, isSelected: boolean) {
    const card = document.getElementById(`page-card-${pageId}`);
    if (!card) return;

    const badge = card.querySelector('.card-check-badge') as HTMLElement;
    const checkIcon = card.querySelector('.check-icon') as HTMLElement;

    if (isSelected) {
      card.classList.remove('border-neutral-800', 'hover:border-neutral-700', 'bg-canvas-soft/20');
      card.classList.add('border-primary', 'bg-primary/5', 'shadow-[0_0_15px_rgba(159,232,112,0.1)]');
      
      badge.classList.remove('border-neutral-800', 'bg-canvas-soft/80');
      badge.classList.add('bg-primary', 'border-primary');
      checkIcon.classList.remove('hidden');
    } else {
      card.classList.remove('border-primary', 'bg-primary/5', 'shadow-[0_0_15px_rgba(159,232,112,0.1)]');
      card.classList.add('border-neutral-800', 'bg-canvas-soft/20');
      
      badge.classList.remove('bg-primary', 'border-primary');
      badge.classList.add('border-neutral-800', 'bg-canvas-soft/80');
      checkIcon.classList.add('hidden');
    }
  }

  // Quick Action Selection Helpers
  function selectAll() {
    selectedPages.clear();
    virtualPages.forEach((vp) => {
      selectedPages.add(vp.id);
      setCardSelectedVisual(vp.id, true);
    });
    rangeInput.value = '';
    updateStickyFooter();
  }

  // Quick Action Clear Selection Helpers
  function clearSelection() {
    selectedPages.clear();
    virtualPages.forEach((vp) => {
      setCardSelectedVisual(vp.id, false);
    });
    rangeInput.value = '';
    updateStickyFooter();
  }

  function invertSelection() {
    virtualPages.forEach((vp) => {
      if (selectedPages.has(vp.id)) {
        selectedPages.delete(vp.id);
        setCardSelectedVisual(vp.id, false);
      } else {
        selectedPages.add(vp.id);
        setCardSelectedVisual(vp.id, true);
      }
    });
    rangeInput.value = '';
    updateStickyFooter();
  }

  // Parse Range text fields e.g., '1, 3, 5-8' based on visual order
  function handleRangeInput(e: Event) {
    const value = (e.target as HTMLInputElement).value;
    
    // Clear visual styles
    virtualPages.forEach((vp) => {
      setCardSelectedVisual(vp.id, false);
    });
    selectedPages.clear();

    if (!value.trim()) {
      updateStickyFooter();
      return;
    }

    const totalVirtualPages = virtualPages.length;
    const parts = value.split(',');
    for (const part of parts) {
      const trimmed = part.trim();
      if (!trimmed) continue;

      if (/^\d+$/.test(trimmed)) {
        const visualNum = parseInt(trimmed, 10);
        if (visualNum >= 1 && visualNum <= totalVirtualPages) {
          const virtualIndex = pageOrder[visualNum - 1];
          const vp = virtualPages[virtualIndex];
          selectedPages.add(vp.id);
          setCardSelectedVisual(vp.id, true);
        }
      } else if (/^\d+-\d+$/.test(trimmed)) {
        const [startStr, endStr] = trimmed.split('-');
        let start = parseInt(startStr, 10);
        let end = parseInt(endStr, 10);
        
        if (isNaN(start) || isNaN(end)) continue;
        
        if (start > end) {
          [start, end] = [end, start];
        }

        for (let p = start; p <= end; p++) {
          if (p >= 1 && p <= totalVirtualPages) {
            const virtualIndex = pageOrder[p - 1];
            const vp = virtualPages[virtualIndex];
            selectedPages.add(vp.id);
            setCardSelectedVisual(vp.id, true);
          }
        }
      }
    }

    updateStickyFooter();
  }

  // Real-Time page content search parsing across all active files
  function handleSearchInput(e: Event) {
    const query = (e.target as HTMLInputElement).value.trim().toLowerCase();
    
    if (!query) {
      virtualPages.forEach((vp) => {
        const card = document.getElementById(`page-card-${vp.id}`);
        if (card) card.classList.remove('opacity-25');
      });
      searchSelectBtn.classList.add('hidden');
      return;
    }

    let matchCount = 0;
    const matchingIds: string[] = [];

    // Filter virtual pages text
    virtualPages.forEach((vp) => {
      const isMatch = vp.text.includes(query);
      const card = document.getElementById(`page-card-${vp.id}`);

      if (card) {
        if (isMatch) {
          card.classList.remove('opacity-25');
          matchCount++;
          matchingIds.push(vp.id);
        } else {
          card.classList.add('opacity-25');
        }
      }
    });

    if (matchCount > 0) {
      searchSelectBtn.textContent = `Select ${matchCount}`;
      searchSelectBtn.classList.remove('hidden');
      
      // Select search matches handler
      searchSelectBtn.onclick = () => {
        matchingIds.forEach((id) => {
          selectedPages.add(id);
          setCardSelectedVisual(id, true);
        });
        updateStickyFooter();
        // Clear search input
        searchInput.value = '';
        handleSearchInput({ target: searchInput } as any);
      };
    } else {
      searchSelectBtn.classList.add('hidden');
    }
  }

  // Footer visual logic
  function updateStickyFooter() {
    const count = selectedPages.size;
    selectedCountLabel.textContent = count.toString();

    if (count > 0) {
      stickyFooter.classList.remove('translate-y-full');
      extractBtn.disabled = false;
      extractBtn.classList.remove('opacity-55', 'cursor-not-allowed');
    } else {
      stickyFooter.classList.add('translate-y-full');
      extractBtn.disabled = true;
      extractBtn.classList.add('opacity-55', 'cursor-not-allowed');
    }
  }

  // Client-Side compilation & merging of multiple PDF pages
  async function executeExtraction() {
    if (selectedPages.size === 0 || loadedPdfDocs.length === 0 || loadedFiles.length === 0) return;

    // Show Loader State
    extractBtn.disabled = true;
    extractBtn.textContent = 'PROCESSING…';
    compilingLoader.classList.remove('hidden');
    compilingLoader.classList.add('flex');

    // Run compiler in next tick to allow DOM spinner to render
    setTimeout(async () => {
      try {
        const newPdfDoc = await PDFDocument.create();
        
        // Find which pages in pageOrder visual array are selected, preserving rearranged visual order
        const selectedVirtualPages = pageOrder
          .map(idx => virtualPages[idx])
          .filter(vp => selectedPages.has(vp.id));
        
        // Copy and append pages from original document references
        for (const vp of selectedVirtualPages) {
          const originalLibDoc = loadedPdfDocs[vp.fileIndex];
          const [copiedPage] = await newPdfDoc.copyPages(originalLibDoc, [vp.pageIndex]);
          newPdfDoc.addPage(copiedPage);
        }
        
        // Save bytes
        const newPdfBytes = await newPdfDoc.save();

        // Download locally in browser
        const blob = new Blob([newPdfBytes], { type: 'application/pdf' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        
        a.href = url;
        let originalBase = 'pageslice_compiled';
        if (loadedFiles.length > 0) {
          originalBase = loadedFiles[0].name.replace(/\.[^/.]+$/, "");
          if (loadedFiles.length > 1) {
            originalBase += `_and_${loadedFiles.length - 1}_other_files`;
          }
        }
        a.download = `${originalBase}_extracted.pdf`;
        
        document.body.appendChild(a);
        a.click();
        
        // Cleanup resources
        setTimeout(() => {
          document.body.removeChild(a);
          URL.revokeObjectURL(url);
        }, 100);

      } catch (err) {
        console.error(err);
        showError('COMPILE ERROR: Page extraction operation failed. Check that pages exist.');
      } finally {
        // Reset states
        extractBtn.disabled = false;
        extractBtn.textContent = 'Extract Selected Pages';
        compilingLoader.classList.remove('flex');
        compilingLoader.classList.add('hidden');
      }
    }, 50);
  }

  // App Reset Logic
  function resetApp() {
    resetState();
    
    // Toggle screens
    dashboardSection.classList.add('hidden');
    dropzoneSection.classList.remove('hidden');
    pdfInput.value = '';
    addFilesInput.value = '';
  }

  function resetState() {
    loadedFiles = [];
    loadedPdfDocs = [];
    loadedPdfJsDocs = [];
    virtualPages = [];
    pageOrder = [];
    selectedPages.clear();
    pendingFile = null;
    pendingFilesList = null;
    filePasswords = {};
    pendingIsAppend = false;
    rangeInput.value = '';
    searchInput.value = '';
    searchSelectBtn.classList.add('hidden');
    updateStickyFooter();
    hideDecryptionPrompt();
  }

  // Utility helpers
  function showError(msg: string) {
    errorMessage.textContent = msg;
    errorBanner.classList.remove('hidden');
    errorBanner.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    
    if (pendingFile) {
      decryptError.classList.remove('hidden');
    }
  }

  // Hide errors
  function hideError() {
    errorBanner.classList.add('hidden');
    decryptError.classList.add('hidden');
  }

  function formatBytes(bytes: number, decimals = 2) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const dm = decimals < 0 ? 0 : decimals;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
  }
</script>

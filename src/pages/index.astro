  // Sanitizes a string for drawing with PDF standard fonts (WinAnsiEncoding)
  function sanitizeTextForWinAnsi(text: string): string {
    if (typeof text !== 'string') return '';
    
    // Replace common unsupported glyphs with ASCII/WinAnsi equivalents
    const replacements: { [key: string]: string } = {
      // Subscripts
      '₀': '0', '₁': '1', '₂': '2', '₃': '3', '₄': '4', '₅': '5', '₆': '6', '₇': '7', '₈': '8', '₉': '9',
      '₊': '+', '₋': '-', '₌': '=', '₍': '(', '₎': ')',
      // Superscripts
      '⁰': '0', '¹': '1', '²': '2', '³': '3', '⁴': '4', '⁵': '5', '⁶': '6', '⁷': '7', '⁸': '8', '⁹': '9',
      '⁺': '+', '⁻': '-', '⁼': '=', '⁽': '(', '⁾': ')',
      // Common Math/Greek
      'α': 'alpha', 'β': 'beta', 'γ': 'gamma', 'δ': 'delta', 'θ': 'theta', 'λ': 'lambda', 'μ': 'mu', 'π': 'pi', 'σ': 'sigma', 'φ': 'phi', 'ω': 'omega',
      'Δ': 'Delta', 'Ω': 'Omega',
      '≈': '~', '≠': '!=', '≤': '<=', '≥': '>=', '±': '+/-', '×': '*', '÷': '/', '−': '-',
      // Other symbols
      '': 'Apple', '✔': 'Y', '✘': 'X', '★': '*', '☆': '*'
    };
    
    let result = '';
    for (let i = 0; i < text.length; i++) {
      const char = text[i];
      if (replacements[char] !== undefined) {
        result += replacements[char];
        continue;
      }
      
      const code = char.charCodeAt(0);
      
      // Check if it's within printable ASCII or standard ISO 8859-1 supplement, or special allowed characters
      const isPrintable = (code >= 0x20 && code <= 0x7E) || (code >= 0xA0 && code <= 0xFF);
      const isAllowedSpecial = 
        code === 0x20AC || code === 0x201A || code === 0x0192 || code === 0x201E || code === 0x2026 || 
        code === 0x2020 || code === 0x2021 || code === 0x02C6 || code === 0x2030 || code === 0x0160 || 
        code === 0x2039 || code === 0x0152 || code === 0x017D || code === 0x2018 || code === 0x2019 || 
        code === 0x201C || code === 0x201D || code === 0x2022 || code === 0x2013 || code === 0x2014 || 
        code === 0x02DC || code === 0x2122 || code === 0x0161 || code === 0x203A || code === 0x0153 || 
        code === 0x017E || code === 0x0178;
        
      if (isPrintable || isAllowedSpecial) {
        result += char;
      } else if (code === 0x09) { // Tab
        result += '    ';
      } else if (code === 0x0A || code === 0x0D) { // Newline / carriage return
        result += ' ';
      } else {
        // Replace with fallback character instead of crashing
        result += '?';
      }
    }
    return result;
  }



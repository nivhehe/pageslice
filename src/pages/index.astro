---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Free PDF Extractor Online - Split & Merge PDF Pages | PageSlice" description="Use the best free PDF extractor tool 2026 to split, delete, organize, or merge PDF pages, images, Word DOCX, and PowerPoint presentations 100% locally in your browser.">
  <!-- SpaceX-inspired dark container with custom grid backgrounds -->
  <main class="spacex-bg min-h-screen text-white relative overflow-hidden flex flex-col font-inter selection:bg-primary selection:text-on-primary">
    
    <!-- Top Decorative Line -->
    <div class="h-1 bg-gradient-to-right from-primary/20 via-primary to-primary/20 w-full"></div>

    <div class="max-w-6xl w-full mx-auto px-4 py-8 sm:px-6 lg:px-8 flex-1 flex flex-col relative z-10">
      
      <Header />

      <!-- Central Content Hub -->
      <div class="flex-1 flex flex-col justify-center">

        <!-- Error Notification Banner -->
        <div id="error-banner" class="hidden border border-negative/50 bg-negative-bg/40 backdrop-blur-md rounded-2xl p-4 mb-6 flex items-center justify-between gap-4 animate-fade-in text-red-200">
          <div class="flex items-center gap-3">
            <svg class="h-5 w-5 text-negative shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <span id="error-message" class="text-sm font-mono uppercase tracking-wider">ERROR: INVALID DOCUMENT FORMAT</span>
          </div>
          <button id="close-error-btn" class="text-mute hover:text-white transition-colors" aria-label="Dismiss error">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <!-- STATE 1: File Dropzone (Default) -->
        <section id="dropzone-section" class="w-full">
          <div 
            id="dropzone" 
            class="border-2 border-dashed border-neutral-800 hover:border-primary/50 transition-all duration-300 rounded-2xl p-12 text-center bg-canvas-soft/30 backdrop-blur-sm cursor-pointer flex flex-col items-center justify-center min-h-[350px] group relative"
          >
            <!-- Grid Background Overlay inside dropzone -->
            <div class="absolute inset-0 spacex-grid opacity-30 rounded-2xl pointer-events-none"></div>

            <div class="relative z-10 flex flex-col items-center">
              <!-- Animated Rocket/Document SVG Icon -->
              <div class="h-16 w-16 mb-6 rounded-full bg-neutral-900 border border-neutral-800 flex items-center justify-center group-hover:border-primary/30 group-hover:scale-110 transition-all duration-300">
                <svg class="h-8 w-8 text-mute group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              </div>

              <h2 class="text-lg font-mono font-bold tracking-widest text-white uppercase mb-2">
                Drag & Drop Files
              </h2>
              <p class="body-sm text-mute mb-6">
                Supports multiple PDF, DOCX, PPTX, and Image (PNG, JPG) files. All files are processed locally.
              </p>

              <!-- Premium Pill Button (Wise + SpaceX styling) -->
              <button 
                id="browse-btn" 
                class="bg-primary text-on-primary hover:bg-primary-active active:scale-95 transition-all rounded-xl px-8 py-3 text-sm font-bold tracking-wider uppercase border border-primary/20 glow-primary hover:glow-primary-strong"
              >
                Browse Files
              </button>
              
              <input type="file" id="pdf-input" class="hidden" accept=".pdf,.docx,.pptx,.png,.jpg,.jpeg" multiple />
            </div>
          </div>

          <!-- Feature Advantages Grid (Sleek telemetry styling) -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-8 font-mono text-left">
            <div class="border border-neutral-800 bg-canvas/40 backdrop-blur-md p-5 rounded-2xl flex flex-col justify-between hover:border-primary/20 transition-all duration-300">
              <div>
                <span class="text-[10px] text-primary uppercase tracking-widest font-bold">SPEED SPEC</span>
                <h3 class="text-sm font-bold text-white uppercase mt-2 mb-1">Instant Processing</h3>
                <p class="text-xs text-mute font-inter leading-relaxed">No upload times. Multiple document compilation is done locally in your browser memory within milliseconds.</p>
              </div>
            </div>
            
            <div class="border border-neutral-800 bg-canvas/40 backdrop-blur-md p-5 rounded-2xl flex flex-col justify-between hover:border-primary/20 transition-all duration-300">
              <div>
                <span class="text-[10px] text-primary uppercase tracking-widest font-bold">ACCESS SPEC</span>
                <h3 class="text-sm font-bold text-white uppercase mt-2 mb-1">Zero Friction</h3>
                <p class="text-xs text-mute font-inter leading-relaxed">No login, registration, or emails required. Instant utility tools, ready when you are.</p>
              </div>
            </div>
            
            <div class="border border-neutral-800 bg-canvas/40 backdrop-blur-md p-5 rounded-2xl flex flex-col justify-between hover:border-primary/20 transition-all duration-300">
              <div>
                <span class="text-[10px] text-primary uppercase tracking-widest font-bold">COST SPEC</span>
                <h3 class="text-sm font-bold text-white uppercase mt-2 mb-1">100% Free & Private</h3>
                <p class="text-xs text-mute font-inter leading-relaxed">Zero subscription fees or usage caps. Client-side execution sandboxes files on your device.</p>
              </div>
            </div>

            <div class="border border-neutral-800 bg-canvas/40 backdrop-blur-md p-5 rounded-2xl flex flex-col justify-between hover:border-primary/20 transition-all duration-300">

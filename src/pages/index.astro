  function movePageInOrder(visualIndex: number, direction: number) {
    const toIndex = visualIndex + direction;
    if (toIndex >= 0 && toIndex < pageOrder.length) {
      const draggedVirtualIndex = pageOrder[visualIndex];
      // Swap or insert
      pageOrder.splice(visualIndex, 1);
      pageOrder.splice(toIndex, 0, draggedVirtualIndex);
      renderPagesGrid();
    }
  }

  // HTML5 Drag-and-drop mechanics
  let draggedIndex: number | null = null;

  function setupDragEvents(card: HTMLElement, virtualIndex: number) {
    card.addEventListener('dragstart', (e) => {
      draggedIndex = virtualIndex;
      card.classList.add('opacity-50', 'scale-95', 'border-primary/50');
      if (e.dataTransfer) {
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', virtualIndex.toString());
      }
    });

    card.addEventListener('dragend', () => {
      card.classList.remove('opacity-50', 'scale-95', 'border-primary/50');
      
      // Clean up drop outlines across cards
      const allCards = pagesGrid.querySelectorAll('[id^="page-card-"]');
      allCards.forEach(c => c.classList.remove('border-primary'));
    });

    card.addEventListener('dragover', (e) => {
      e.preventDefault();
      if (draggedIndex === null || draggedIndex === virtualIndex) return;

      if (e.dataTransfer) {
        e.dataTransfer.dropEffect = 'move';
      }
      card.classList.add('border-primary/50');
    });

    card.addEventListener('dragleave', () => {
      if (draggedIndex === null || draggedIndex === virtualIndex) return;
      card.classList.remove('border-primary/50');
    });

    card.addEventListener('drop', (e) => {
      e.preventDefault();
      card.classList.remove('border-primary/50');
      
      if (draggedIndex === null || draggedIndex === virtualIndex) return;

      const fromIndex = pageOrder.indexOf(draggedIndex);
      const toIndex = pageOrder.indexOf(virtualIndex);

      if (fromIndex !== -1 && toIndex !== -1) {
        // Swap indices sequences
        pageOrder.splice(fromIndex, 1);
        pageOrder.splice(toIndex, 0, draggedIndex);

        // Re-draw grid to visually map new order sequence
        renderPagesGrid();
      }
    });
  }

  async function renderPageThumbnail(pdfJsDoc: any, pageIndex: number, pageId: string) {
    try {
      const page = await pdfJsDoc.getPage(pageIndex + 1);
      const canvas = document.getElementById(`canvas-page-${pageId}`) as HTMLCanvasElement;
      if (!canvas) return;

      const context = canvas.getContext('2d');
      if (!context) return;

      // Adjust scale to a standard thumbnail width (180px)
      const desiredWidth = 180;
      const originalViewport = page.getViewport({ scale: 1 });
      const scale = desiredWidth / originalViewport.width;
      const viewport = page.getViewport({ scale });

      canvas.width = viewport.width;
      canvas.height = viewport.height;

      // Cancel existing rendering task for this specific page thumbnail if active
      if (activeRenderTasks[pageId]) {
        try {
          activeRenderTasks[pageId].cancel();
        } catch (cancelErr) {
          // Ignore cancellation errors
        }
      }

      const renderContext = {
        canvasContext: context,
        viewport: viewport
      };

      const renderTask = page.render(renderContext);
      activeRenderTasks[pageId] = renderTask;

      await renderTask.promise;
      delete activeRenderTasks[pageId];

      // Draw existing edits on the thumbnail canvas
      if (pageEdits[pageId]) {
        drawEditsOnCanvas(canvas, viewport, pageEdits[pageId]);
      }

      // Hide loader
      const loader = document.getElementById(`loader-page-${pageId}`);
      if (loader) loader.classList.add('hidden');
    } catch (err: any) {
      if (err && err.name === 'RenderingCancelledException') {
        // Safe to ignore since we cancelled it ourselves
        return;
      }
      console.error(`Error rendering page thumbnail ${pageId}:`, err);
      const loader = document.getElementById(`loader-page-${pageId}`);
      if (loader) loader.textContent = 'ERROR';
    }
  }

  // Decryption Prompt Modal Helpers
  function showDecryptionPromptForFile(file: File, files: File[], index: number, append = false) {
    pendingFile = file;
    pendingFilesList = files;
    pendingFileIndex = index;
    pendingIsAppend = append;
    
    decryptFilename.textContent = file.name;
    decryptPasswordInput.value = '';
    decryptError.classList.add('hidden');
    decryptModal.classList.remove('hidden');
    decryptPasswordInput.focus();

    // Reset browse button state
    const activeBtn = append ? addFilesBtn : browseBtn;
    if (activeBtn) {
      activeBtn.textContent = append ? 'Add Files' : 'Browse Files';
      activeBtn.disabled = false;
    }
  }

  function hideDecryptionPrompt() {
    decryptModal.classList.add('hidden');
    pendingFile = null;
    pendingFilesList = null;
  }

  function submitPassword() {
    const password = decryptPasswordInput.value;
    if (pendingFile && pendingFilesList) {
      decryptError.classList.add('hidden');
      filePasswords[pendingFileIndex] = password;
      
      if (pendingIsAppend) {
        const countBeforeAppend = pendingFileIndex - pendingFilesList.indexOf(pendingFile);
        loadedFiles = loadedFiles.slice(0, countBeforeAppend);
      }
      
      processFiles(pendingFilesList, pendingIsAppend);
    }
  }

  function abortDecryption() {
    hideDecryptionPrompt();
    resetState();
    pdfInput.value = '';
    addFilesInput.value = '';
  }

  // ==========================================
  // PDF Editing and Font Mapping Module
  // ==========================================

  function mapFontName(originalFontName: string): any {
    const name = (originalFontName || '').toLowerCase();
    const isBold = name.includes('bold') || name.includes('heavy') || name.includes('black') || name.includes('w-700') || name.includes('w-800') || name.includes('w-900') || name.includes('g_d0_f2');
    const isItalic = name.includes('italic') || name.includes('oblique') || name.includes('slanted') || name.includes('skewed');

    if (name.includes('times') || name.includes('roman') || (name.includes('serif') && !name.includes('sans-serif') && !name.includes('sansserif')) || name.includes('georgia') || name.includes('cambria') || name.includes('garamond') || name.includes('bookman') || name.includes('palatino')) {
      if (isBold && isItalic) return StandardFonts.TimesRomanBoldItalic;
      if (isBold) return StandardFonts.TimesRomanBold;
      if (isItalic) return StandardFonts.TimesRomanItalic;
      return StandardFonts.TimesRoman;
    }

    if (name.includes('courier') || name.includes('mono') || name.includes('consolas') || name.includes('code') || name.includes('monospace')) {
      if (isBold && isItalic) return StandardFonts.CourierBoldOblique;
      if (isBold) return StandardFonts.CourierBold;
      if (isItalic) return StandardFonts.CourierOblique;
      return StandardFonts.Courier;
    }

    // Default to Helvetica
    if (isBold && isItalic) return StandardFonts.HelveticaBoldOblique;
    if (isBold) return StandardFonts.HelveticaBold;
    if (isItalic) return StandardFonts.HelveticaOblique;
    return StandardFonts.Helvetica;
  }

  function setupColorButtons() {
    const colorBlack = document.getElementById('color-black-btn') as HTMLButtonElement;
    const colorWhite = document.getElementById('color-white-btn') as HTMLButtonElement;
    const colorRed = document.getElementById('color-red-btn') as HTMLButtonElement;
    const colorBlue = document.getElementById('color-blue-btn') as HTMLButtonElement;
    
    if (!colorBlack || !colorWhite || !colorRed || !colorBlue) return;

    function setTextColorSelected(color: string) {
      modalTextColor = color;
      [colorBlack, colorWhite, colorRed, colorBlue].forEach(btn => btn.classList.remove('ring-2', 'ring-primary', 'ring-offset-2', 'ring-offset-canvas'));
      if (color === 'black') colorBlack.classList.add('ring-2', 'ring-primary', 'ring-offset-2', 'ring-offset-canvas');
      else if (color === 'white') colorWhite.classList.add('ring-2', 'ring-primary', 'ring-offset-2', 'ring-offset-canvas');
      else if (color === 'red') colorRed.classList.add('ring-2', 'ring-primary', 'ring-offset-2', 'ring-offset-canvas');
      else if (color === 'blue') colorBlue.classList.add('ring-2', 'ring-primary', 'ring-offset-2', 'ring-offset-canvas');
      
      if (currentEditingPageId) {
        redrawEditCanvas();
      }
    }
    
    colorBlack.addEventListener('click', () => setTextColorSelected('black'));
    colorWhite.addEventListener('click', () => setTextColorSelected('white'));
    colorRed.addEventListener('click', () => setTextColorSelected('red'));
    colorBlue.addEventListener('click', () => setTextColorSelected('blue'));
    
    // Bind to window for external state sync
    (window as any).setModalTextColor = setTextColorSelected;
  }

  function getStandardFontName(family: string, isBold: boolean, isItalic: boolean): any {
    if (family === 'times') {
      if (isBold && isItalic) return StandardFonts.TimesRomanBoldItalic;
      if (isBold) return StandardFonts.TimesRomanBold;
      if (isItalic) return StandardFonts.TimesRomanItalic;
      return StandardFonts.TimesRoman;
    }
    if (family === 'courier') {
      if (isBold && isItalic) return StandardFonts.CourierBoldOblique;
      if (isBold) return StandardFonts.CourierBold;
      if (isItalic) return StandardFonts.CourierOblique;
      return StandardFonts.Courier;
    }
    // Default to Helvetica
    if (isBold && isItalic) return StandardFonts.HelveticaBoldOblique;
    if (isBold) return StandardFonts.HelveticaBold;
    if (isItalic) return StandardFonts.HelveticaOblique;
    return StandardFonts.Helvetica;
  }

  function setActiveSegment(idx: number | null, editItem: any = null) {
    activeSegmentIndex = idx;
    
    const sizeDecBtn = document.getElementById('font-size-dec-btn') as HTMLButtonElement;
    const sizeIncBtn = document.getElementById('font-size-inc-btn') as HTMLButtonElement;
    const sizeDisplay = document.getElementById('font-size-display-val') as HTMLElement;
    const boldBtn = document.getElementById('style-bold-btn') as HTMLButtonElement;
    const italicBtn = document.getElementById('style-italic-btn') as HTMLButtonElement;
    const underlineBtn = document.getElementById('style-underline-btn') as HTMLButtonElement;
    
    if (!sizeDecBtn || !sizeIncBtn || !sizeDisplay || !boldBtn || !italicBtn || !underlineBtn) return;
    
    if (idx === null || !editItem) {
      sizeDecBtn.disabled = true;
      sizeIncBtn.disabled = true;
      sizeDisplay.textContent = '--';
      boldBtn.disabled = true;
      italicBtn.disabled = true;
      underlineBtn.disabled = true;
      
      [boldBtn, italicBtn, underlineBtn].forEach(btn => btn.classList.remove('bg-primary/20', 'border-primary', 'text-primary'));
      return;
    }
    
    sizeDecBtn.disabled = false;
    sizeIncBtn.disabled = false;
    sizeDisplay.textContent = Math.round(editItem.fontSize).toString();
    
    boldBtn.disabled = false;
    italicBtn.disabled = false;
    underlineBtn.disabled = false;
    
    if (editItem.isBold) {
      boldBtn.classList.add('bg-primary/20', 'border-primary', 'text-primary');
    } else {
      boldBtn.classList.remove('bg-primary/20', 'border-primary', 'text-primary');
    }
    
    if (editItem.isItalic) {
      italicBtn.classList.add('bg-primary/20', 'border-primary', 'text-primary');
    } else {
      italicBtn.classList.remove('bg-primary/20', 'border-primary', 'text-primary');
    }
    
    if (editItem.isUnderlined) {
      underlineBtn.classList.add('bg-primary/20', 'border-primary', 'text-primary');
    } else {
      underlineBtn.classList.remove('bg-primary/20', 'border-primary', 'text-primary');
    }
  }

  function setupStyleControlButtons() {
    const sizeDecBtn = document.getElementById('font-size-dec-btn') as HTMLButtonElement;
    const sizeIncBtn = document.getElementById('font-size-inc-btn') as HTMLButtonElement;
    const boldBtn = document.getElementById('style-bold-btn') as HTMLButtonElement;
    const italicBtn = document.getElementById('style-italic-btn') as HTMLButtonElement;
    const underlineBtn = document.getElementById('style-underline-btn') as HTMLButtonElement;
    
    if (!sizeDecBtn || !sizeIncBtn || !boldBtn || !italicBtn || !underlineBtn) return;
    
    sizeDecBtn.addEventListener('click', () => {
      if (activeSegmentIndex === null) return;
      const editItem = tempModalEdits.find(item => item.index === activeSegmentIndex);
      if (editItem) {
        pushUndoState(editItem);
        editItem.fontSize = Math.max(4, editItem.fontSize - 1);
        setActiveSegment(activeSegmentIndex, editItem);
        redrawEditCanvas();
        const listContainer = document.getElementById('edit-text-list') as HTMLElement;
        const listItem = listContainer?.querySelector(`textarea[data-index="${activeSegmentIndex}"]`)?.closest('div') as HTMLElement;
        if (listItem) markAsModified(listItem, editItem);
      }
    });
    
    sizeIncBtn.addEventListener('click', () => {
      if (activeSegmentIndex === null) return;
      const editItem = tempModalEdits.find(item => item.index === activeSegmentIndex);
      if (editItem) {
        pushUndoState(editItem);
        editItem.fontSize = Math.min(100, editItem.fontSize + 1);
        setActiveSegment(activeSegmentIndex, editItem);
        redrawEditCanvas();
        const listContainer = document.getElementById('edit-text-list') as HTMLElement;
        const listItem = listContainer?.querySelector(`textarea[data-index="${activeSegmentIndex}"]`)?.closest('div') as HTMLElement;
        if (listItem) markAsModified(listItem, editItem);
      }
    });
    
    boldBtn.addEventListener('click', () => {
      if (activeSegmentIndex === null) return;
      const editItem = tempModalEdits.find(item => item.index === activeSegmentIndex);
      if (editItem) {
        pushUndoState(editItem);
        editItem.isBold = !editItem.isBold;
        editItem.fontNameMapped = getStandardFontName(editItem.fontFamilyGroup || 'helvetica', editItem.isBold, editItem.isItalic);
        setActiveSegment(activeSegmentIndex, editItem);
        redrawEditCanvas();
        const listContainer = document.getElementById('edit-text-list') as HTMLElement;
        const listItem = listContainer?.querySelector(`textarea[data-index="${activeSegmentIndex}"]`)?.closest('div') as HTMLElement;
        if (listItem) markAsModified(listItem, editItem);
      }
    });
    
    italicBtn.addEventListener('click', () => {
      if (activeSegmentIndex === null) return;
      const editItem = tempModalEdits.find(item => item.index === activeSegmentIndex);
      if (editItem) {
        pushUndoState(editItem);
        editItem.isItalic = !editItem.isItalic;
        editItem.fontNameMapped = getStandardFontName(editItem.fontFamilyGroup || 'helvetica', editItem.isBold, editItem.isItalic);
        setActiveSegment(activeSegmentIndex, editItem);
        redrawEditCanvas();
        const listContainer = document.getElementById('edit-text-list') as HTMLElement;
        const listItem = listContainer?.querySelector(`textarea[data-index="${activeSegmentIndex}"]`)?.closest('div') as HTMLElement;
        if (listItem) markAsModified(listItem, editItem);
      }
    });
    
    underlineBtn.addEventListener('click', () => {
      if (activeSegmentIndex === null) return;
      const editItem = tempModalEdits.find(item => item.index === activeSegmentIndex);
      if (editItem) {
        pushUndoState(editItem);
        editItem.isUnderlined = !editItem.isUnderlined;
        setActiveSegment(activeSegmentIndex, editItem);
        redrawEditCanvas();
        const listContainer = document.getElementById('edit-text-list') as HTMLElement;
        const listItem = listContainer?.querySelector(`textarea[data-index="${activeSegmentIndex}"]`)?.closest('div') as HTMLElement;
        if (listItem) markAsModified(listItem, editItem);
      }
    });
  }

  function drawEditsOnCanvas(canvas: HTMLCanvasElement, viewport: any, edits: any) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    
    ctx.save();
    
    edits.items.forEach((item: any) => {
      const isModified = item.editedText !== item.originalText || 
                         item.fontSize !== (item.originalFontSize || item.fontSize) || 
                         item.isBold !== (item.originalIsBold || false) || 
                         item.isItalic !== (item.originalIsItalic || false) || 
                         item.isUnderlined;
      if (isModified) {
        const [x, y] = viewport.convertToViewportPoint(item.x, item.y);
        const fontSize = item.fontSize * viewport.scale;
        
        // Compute cover rectangle using original size
        const origFontSize = (item.originalFontSize || item.fontSize) * viewport.scale;
        const origWidth = item.width * viewport.scale;
        const coverHeight = origFontSize * 1.35;
        
        const bg = item.bgColor || { r: 255, g: 255, b: 255 };
        ctx.fillStyle = `rgb(${bg.r}, ${bg.g}, ${bg.b})`;
        ctx.fillRect(x, y - origFontSize * 1.0, origWidth * 1.05, coverHeight);
        
        let fontStyle = '';
        if (item.isBold) fontStyle += 'bold ';
        if (item.isItalic) fontStyle += 'italic ';
        
        let cssFontFamily = '';
        if (item.fontFamilyOriginal) {
          const genericFonts = ['sans-serif', 'serif', 'monospace', 'cursive', 'fantasy', 'system-ui'];
          if (genericFonts.includes(item.fontFamilyOriginal.toLowerCase())) {
            cssFontFamily = `${item.fontFamilyOriginal}, `;
          } else {
            cssFontFamily = `"${item.fontFamilyOriginal}", `;
          }
        }
        
        if (item.fontFamilyGroup === 'times') {
          cssFontFamily += '"Times New Roman", Georgia, "Times", serif';
        } else if (item.fontFamilyGroup === 'courier') {
          cssFontFamily += '"Courier New", Consolas, Monaco, monospace';
        } else {
          cssFontFamily += 'Helvetica, Arial, system-ui, sans-serif';
        }
        ctx.font = `${fontStyle}${fontSize}px ${cssFontFamily}`;
        
        let textColor = '#000000';
        if (edits.textColor === 'white') textColor = '#ffffff';
        else if (edits.textColor === 'red') textColor = '#dc2626';
        else if (edits.textColor === 'blue') textColor = '#2563eb';
        
        ctx.fillStyle = textColor;
        ctx.textBaseline = 'alphabetic';
        ctx.fillText(item.editedText, x, y);
        
        if (item.isUnderlined) {
          ctx.strokeStyle = textColor;
          ctx.lineWidth = Math.max(1, fontSize * 0.07);
          ctx.beginPath();
          ctx.moveTo(x, y + fontSize * 0.1);
          const textWidth = ctx.measureText(item.editedText).width;
          ctx.lineTo(x + textWidth, y + fontSize * 0.1);
          ctx.stroke();
        }
      }
    });
    
    ctx.restore();
  }

  function redrawEditCanvas() {
    if (!currentEditingPageId) return;
    if (_redrawRafId) cancelAnimationFrame(_redrawRafId);
    _redrawRafId = requestAnimationFrame(() => {
      _redrawRafId = 0;
      const canvas = document.getElementById('edit-page-canvas') as HTMLCanvasElement;
      if (!canvas || !cleanOffscreenCanvas || !currentViewport) return;
      const context = canvas.getContext('2d');
      if (!context) return;
      context.clearRect(0, 0, canvas.width, canvas.height);
      context.drawImage(cleanOffscreenCanvas, 0, 0);
      drawEditsOnCanvas(canvas, currentViewport, { items: tempModalEdits, textColor: modalTextColor });
      updatePreviewCanvas();
    });
  }

  async function renderEditCanvas(pageId: string) {
    const vp = virtualPages.find(p => p.id === pageId);
    if (!vp) return;
    
    const pdfJsDoc = loadedPdfJsDocs[vp.fileIndex];
    const page = await pdfJsDoc.getPage(vp.pageIndex + 1);
    
    const canvas = document.getElementById('edit-page-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    
    const context = canvas.getContext('2d');
    if (!context) return;
    
    const desiredHeight = 600;
    const originalViewport = page.getViewport({ scale: 1 });
    const scale = desiredHeight / originalViewport.height;
    const viewport = page.getViewport({ scale });
    
    canvas.width = viewport.width;
    canvas.height = viewport.height;
    
    const container = document.getElementById('edit-canvas-container') as HTMLElement;
    if (container) {
      container.style.width = viewport.width + 'px';
      container.style.height = viewport.height + 'px';
    }
    
    if (activeEditCanvasRenderTask) {
      try {
        activeEditCanvasRenderTask.cancel();
      } catch (e) {}
    }

    const renderContext = {
      canvasContext: context,
      viewport: viewport
    };
    
    try {
      const renderTask = page.render(renderContext);
      activeEditCanvasRenderTask = renderTask;
      await renderTask.promise;
      if (activeEditCanvasRenderTask === renderTask) {
        activeEditCanvasRenderTask = null;
      }
      
      const edits = pageEdits[pageId] || { items: [], textColor: 'black' };
      if (pageEdits[pageId]) {
        drawEditsOnCanvas(canvas, viewport, edits);
      }
      
      renderTextOverlays(page, viewport, pageId, edits, canvas);
    } catch (err: any) {
      if (err && err.name === 'RenderingCancelledException') {
        return;
      }
      console.error(err);
    }
  }

  function sampleBackgroundColor(canvas: HTMLCanvasElement, viewport: any, x: number, y: number, fontSize: number): { r: number, g: number, b: number } {
    if (!canvas || canvas.width <= 0 || canvas.height <= 0) {
      return { r: 255, g: 255, b: 255 };
    }
    const ctx = canvas.getContext('2d');
    if (!ctx) return { r: 255, g: 255, b: 255 };
    
    // 1. Sample page-wide background color (at 10, 10) as a default / fallback
    let defaultBg = { r: 255, g: 255, b: 255 };
    try {
      const pageBgX = Math.max(0, Math.min(canvas.width - 1, 10));
      const pageBgY = Math.max(0, Math.min(canvas.height - 1, 10));
      const pageBgData = ctx.getImageData(pageBgX, pageBgY, 1, 1).data;
      if (pageBgData[3] !== 0) {
        defaultBg = { r: pageBgData[0], g: pageBgData[1], b: pageBgData[2] };
      }
    } catch (e) {
      // ignore
    }
    
    const transformX = x || 0;
    const transformY = (y || 0) + (fontSize || 12) * 0.4;
    
    if (!viewport || typeof viewport.convertToViewportPoint !== 'function') {
      return defaultBg;
    }

    const [canvasX, canvasY] = viewport.convertToViewportPoint(transformX, transformY);
    
    if (isNaN(canvasX) || isNaN(canvasY) || !isFinite(canvasX) || !isFinite(canvasY)) {
      return defaultBg;
    }
    
    try {
      // 2. Sample two points to the left of the text (in the margin/space before text)
      const sx1 = Math.max(0, Math.min(canvas.width - 1, Math.round(canvasX - 8)));
      const sy1 = Math.max(0, Math.min(canvas.height - 1, Math.round(canvasY)));
      const c1Data = ctx.getImageData(sx1, sy1, 1, 1).data;
      
      const sx2 = Math.max(0, Math.min(canvas.width - 1, Math.round(canvasX - 16)));
      const sy2 = Math.max(0, Math.min(canvas.height - 1, Math.round(canvasY)));
      const c2Data = ctx.getImageData(sx2, sy2, 1, 1).data;
      
      if (c1Data[3] !== 0 && c2Data[3] !== 0) {
        const c1 = { r: c1Data[0], g: c1Data[1], b: c1Data[2] };
        const c2 = { r: c2Data[0], g: c2Data[1], b: c2Data[2] };
        
        // If these two points are almost identical in color, it is a uniform local background color
        const diff = Math.abs(c1.r - c2.r) + Math.abs(c1.g - c2.g) + Math.abs(c1.b - c2.b);
        if (diff < 15) {
          return c1;
        }
      }
      
      // 3. Fallback: Check all candidates and compare to defaultBg or pick brightest
      const candidates = [
        { x: canvasX - 8, y: canvasY },
        { x: canvasX - 16, y: canvasY },
        { x: canvasX + 4, y: canvasY - (fontSize || 12) * 0.8 }
      ];
      
      let bestColor = { r: defaultBg.r, g: defaultBg.g, b: defaultBg.b, score: -1 };
      const defaultBgScore = defaultBg.r + defaultBg.g + defaultBg.b;
      const isDarkPage = defaultBgScore < 380;
      
      for (const cand of candidates) {
        const sx = Math.max(0, Math.min(canvas.width - 1, Math.round(cand.x)));
        const sy = Math.max(0, Math.min(canvas.height - 1, Math.round(cand.y)));
        
        const imgData = ctx.getImageData(sx, sy, 1, 1).data;
        if (imgData[3] === 0) continue; // transparent
        
        const r = imgData[0];
        const g = imgData[1];
        const b = imgData[2];
        const score = r + g + b;
        
        if (isDarkPage) {
          // On a dark page, we want the candidate closest in color to the default page background
          const dist = Math.abs(r - defaultBg.r) + Math.abs(g - defaultBg.g) + Math.abs(b - defaultBg.b);
          if (bestColor.score === -1 || dist < bestColor.score) {
            bestColor = { r, g, b, score: dist };
          }
        } else {
          // On a light page, the background is typically the brightest element (largest RGB sum)
          if (score > bestColor.score) {
            bestColor = { r, g, b, score };
          }
        }
      }
      
      if (bestColor.score >= 0) {
        if (isDarkPage) {
          return { r: bestColor.r, g: bestColor.g, b: bestColor.b };
        } else {
          // Fallback to defaultBg if the brightest candidate is still too dark on a light page
          if (bestColor.score < 300) {
            return defaultBg;
          }
          return { r: bestColor.r, g: bestColor.g, b: bestColor.b };
        }
      }
    } catch (e) {
      console.warn("Error sampling background color:", e);
    }
    
    return defaultBg;
  }

  async function renderTextOverlays(page: any, viewport: any, pageId: string, currentEdits: any, canvas: HTMLCanvasElement) {
    const overlay = document.getElementById('edit-text-overlay') as HTMLElement;
    const listContainer = document.getElementById('edit-text-list') as HTMLElement;
    
    if (!overlay || !listContainer) return;
    
    overlay.innerHTML = '';
    listContainer.innerHTML = '';
    
    try {
      const textContent = await page.getTextContent();
      const hasEdits = currentEdits && currentEdits.items && currentEdits.items.length > 0;
      const editItems = hasEdits ? JSON.parse(JSON.stringify(currentEdits.items)) : [];
      
      const validItems = textContent.items.filter((item: any) => item && item.transform && Array.isArray(item.transform) && item.transform.length >= 6);
      
      const segmentCountEl = document.getElementById('edit-segment-count') as HTMLElement;
      if (segmentCountEl) segmentCountEl.textContent = `${validItems.length} Items`;
      
      if (validItems.length === 0) {
        listContainer.innerHTML = `
          <div class="p-6 border border-neutral-800 bg-neutral-950/20 rounded-xl text-center font-mono text-xs text-mute flex flex-col items-center justify-center gap-3 h-full min-h-[220px]">
            <svg class="h-8 w-8 text-neutral-600 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <span class="font-bold uppercase tracking-wider text-white">No Text Detected</span>
            <span class="leading-relaxed text-[10px] text-neutral-500 max-w-[240px]">
              This page appears to contain only images or scanned content. Direct text editing is only supported for digital text layers.
            </span>
          </div>
        `;
        tempModalEdits = [];
        return;
      }
      
      validItems.forEach((item: any, idx: number) => {
        try {
          const styles = textContent.styles || {};
          const style = styles[item.fontName] || {};
          const fontFamilyName = style.fontFamily || '';

          // Retrieve font metadata from PDF.js page resources dynamically
          let pdfJsFont = null;
          try {
            if (page.commonObjs && typeof page.commonObjs.has === 'function' && page.commonObjs.has(item.fontName)) {
              pdfJsFont = page.commonObjs.get(item.fontName);
            } else if (page.objs && typeof page.objs.has === 'function' && page.objs.has(item.fontName)) {
              pdfJsFont = page.objs.get(item.fontName);
            }
          } catch (e) {
            console.warn("Failed to retrieve font object from PDF.js page resources:", e);
          }

          const psNameLower = (pdfJsFont && typeof pdfJsFont.name === 'string' ? pdfJsFont.name : '').toLowerCase();
          const fallbackLower = (pdfJsFont && typeof pdfJsFont.fallbackName === 'string' ? pdfJsFont.fallbackName : '').toLowerCase();
          const nameLower = (item.fontName || '').toLowerCase();
          const familyLower = fontFamilyName.toLowerCase();

          // Robust check for bold/italic using both boolean properties and string patterns
          let originalIsBold = false;
          if (pdfJsFont && typeof pdfJsFont.bold === 'boolean') {
            originalIsBold = pdfJsFont.bold;
          }
          if (!originalIsBold) {
            originalIsBold = psNameLower.includes('bold') || psNameLower.includes('heavy') || psNameLower.includes('black') || 
                             psNameLower.includes('-bold') || psNameLower.includes('_bold') || psNameLower.includes('w-700') || 
                             psNameLower.includes('w-800') || psNameLower.includes('w-900') ||
                             fallbackLower.includes('bold') || nameLower.includes('bold') || familyLower.includes('bold') || 
                             nameLower.includes('g_d0_f2');
          }

          let originalIsItalic = false;
          if (pdfJsFont && typeof pdfJsFont.italic === 'boolean') {
            originalIsItalic = pdfJsFont.italic;
          }
          if (!originalIsItalic) {
            originalIsItalic = psNameLower.includes('italic') || psNameLower.includes('oblique') || 
                               psNameLower.includes('slanted') || psNameLower.includes('skewed') || 
                               fallbackLower.includes('italic') || nameLower.includes('italic') || familyLower.includes('italic');
          }

          // Gather all font clues for mapFontName to resolve standard PDF fonts
          let fontClues = fontFamilyName + ' ' + (item.fontName || '') + ' ' + psNameLower + ' ' + fallbackLower;
          if (originalIsBold) fontClues += ' bold';
          if (originalIsItalic) fontClues += ' italic';
          const mappedFont = mapFontName(fontClues);
          
          let family = 'helvetica';
          const cluesLower = fontClues.toLowerCase();
          if (cluesLower.includes('times') || cluesLower.includes('roman') || (cluesLower.includes('serif') && !cluesLower.includes('sans-serif') && !cluesLower.includes('sansserif')) || cluesLower.includes('georgia') || cluesLower.includes('cambria') || cluesLower.includes('garamond') || cluesLower.includes('bookman') || cluesLower.includes('palatino')) {
            family = 'times';
          } else if (cluesLower.includes('courier') || cluesLower.includes('mono') || cluesLower.includes('consolas') || cluesLower.includes('code') || cluesLower.includes('monospace')) {
            family = 'courier';
          }
          
          let editItem = editItems.find((e: any) => e.index === idx);
          
          const itemX = (item.transform && item.transform[4]) || 0;
          const itemY = (item.transform && item.transform[5]) || 0;
          const itemScale = (item.transform && item.transform[3]) || 12;
          const sampledBg = sampleBackgroundColor(canvas, viewport, itemX, itemY, itemScale);
          
          if (!editItem) {
            editItem = {
              index: idx,
              originalText: item.str || '',
              editedText: item.str || '',
              x: itemX,
              y: itemY,
              width: item.width || 0,
              height: item.height || itemScale || 12,
              fontSize: itemScale || 12,
              originalFontSize: itemScale || 12,
              fontFamilyGroup: family,
              fontFamilyOriginal: fontFamilyName,
              isBold: originalIsBold,
              originalIsBold: originalIsBold,
              isItalic: originalIsItalic,
              originalIsItalic: originalIsItalic,
              isUnderlined: false,
              fontNameMapped: mappedFont,
              fontNameOriginal: item.fontName || '',
              bgColor: sampledBg
            };
            editItems.push(editItem);
          } else {
            editItem.bgColor = sampledBg;
            if (editItem.isBold === undefined) editItem.isBold = originalIsBold;
            if (editItem.isItalic === undefined) editItem.isItalic = originalIsItalic;
            if (editItem.isUnderlined === undefined) editItem.isUnderlined = false;
            if (editItem.fontFamilyGroup === undefined) editItem.fontFamilyGroup = family;
            if (editItem.fontFamilyOriginal === undefined) editItem.fontFamilyOriginal = fontFamilyName;
            if (editItem.originalFontSize === undefined) editItem.originalFontSize = editItem.fontSize;
          }
          
          const transformX = itemX;
          const transformY = itemY;
          const transformScale = itemScale;
          
          const [x, y] = viewport.convertToViewportPoint(transformX, transformY);
          const fontSize = transformScale * viewport.scale;
          const width = (item.width || 0) * viewport.scale;
          const height = fontSize * 1.25;
          
          const highlightBox = document.createElement('div');
          highlightBox.className = 'absolute border border-transparent hover:border-primary/40 hover:bg-primary/5 rounded transition-all cursor-pointer z-20';
          
          highlightBox.style.left = `${x}px`;
          highlightBox.style.top = `${y - fontSize * 0.9}px`;
          highlightBox.style.width = `${Math.max(width, 40)}px`;
          highlightBox.style.height = `${height}px`;
          highlightBox.setAttribute('data-index', idx.toString());
          
          const listItem = document.createElement('div');
          listItem.className = 'flex flex-col gap-1.5 p-3 rounded-lg border border-neutral-800 bg-neutral-950/40 hover:border-neutral-700 transition-colors text-left';
          listItem.innerHTML = `
            <div class="flex justify-between items-center text-[8px] font-mono text-mute uppercase">
              <span>Segment #${idx + 1}</span>
              <span class="text-primary truncate max-w-[120px]" title="${fontFamilyName}">${fontFamilyName || 'Helvetica'}</span>
            </div>
            <textarea 
              class="w-full text-xs bg-canvas border border-neutral-800 focus:border-primary focus:outline-none rounded-lg p-2 text-white placeholder:text-neutral-700 transition-all resize-y min-h-[120px] font-sans"
              data-index="${idx}"
              rows="4"
            >${editItem.editedText}</textarea>
          `;
          
          const textarea = listItem.querySelector('textarea') as HTMLTextAreaElement;
          
          // Click on canvas highlight box focuses and scrolls the corresponding sidebar textarea into view
          highlightBox.addEventListener('click', () => {
            textarea.focus();
            textarea.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            setActiveSegment(idx, editItem);
          });
          
          // Update model and trigger real-time preview updates on the canvas as the user types
          textarea.addEventListener('input', () => {
            if (!editItem._undoSaved) {
              undoStack.push(JSON.parse(JSON.stringify(editItem)));
              editItem._undoSaved = true;
            }
            editItem.editedText = textarea.value;
            markAsModified(listItem, editItem);
            redrawEditCanvas();
          });
          
          textarea.addEventListener('focus', () => {
            highlightBox.classList.add('border-primary', 'bg-primary/5');
            highlightBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            setActiveSegment(idx, editItem);
          });
          
          textarea.addEventListener('blur', () => {
            highlightBox.classList.remove('border-primary', 'bg-primary/5');
          });
          
          overlay.appendChild(highlightBox);
          listContainer.appendChild(listItem);
          
          markAsModified(listItem, editItem);
        } catch (itemErr) {
          console.error("Error rendering text segment:", itemErr, item);
        }
      });
      
      tempModalEdits = editItems;
    } catch (err: any) {
      console.error("Error in renderTextOverlays:", err);
      const segmentCountEl = document.getElementById('edit-segment-count') as HTMLElement;
      if (segmentCountEl) segmentCountEl.textContent = `Error`;
      
      listContainer.innerHTML = `
        <div class="p-4 border border-red-500/20 bg-red-500/5 rounded-xl text-center font-mono text-xs text-red-400">
          <span class="font-bold uppercase tracking-wider block mb-1">Text Extraction Failed</span>
          ${err.message || err}
        </div>
      `;
      tempModalEdits = [];
    }
  }

  function markAsModified(listItem: HTMLElement, editItem: any) {
    const isModified = editItem.editedText !== editItem.originalText || 
                       editItem.fontSize !== (editItem.originalFontSize || editItem.fontSize) || 
                       editItem.isBold !== (editItem.originalIsBold || false) || 
                       editItem.isItalic !== (editItem.originalIsItalic || false) || 
                       editItem.isUnderlined;
                       
    if (isModified) {
      listItem.classList.add('border-primary/40');
      const badge = listItem.querySelector('span') as HTMLElement;
      if (badge && !badge.textContent?.includes('EDITED')) {
        badge.innerHTML = `Segment #${editItem.index + 1} <span class="text-primary font-bold ml-1.5">[EDITED]</span>`;
      }
    } else {
      listItem.classList.remove('border-primary/40');
      const badge = listItem.querySelector('span') as HTMLElement;
      if (badge) {
        badge.innerHTML = `Segment #${editItem.index + 1}`;
      }
    }
  }

  async function openEditModal(pageId: string) {
    const editablePages = pageOrder
      .map(idx => virtualPages[idx])
      .filter(vp => {
        const ext = vp.fileName.split('.').pop()?.toLowerCase() || '';
        return ['pdf', 'pptx', 'docx'].includes(ext);
      });
      
    if (editablePages.length === 0) return;
    
    // Setup temporary session edits starting with the current state of pageEdits
    tempSessionEdits = JSON.parse(JSON.stringify(pageEdits));
    
    // Setup select options
    const pageSelect = document.getElementById('edit-page-select') as HTMLSelectElement;
    if (pageSelect) {
      pageSelect.innerHTML = '';
      editablePages.forEach((vp, index) => {
        const opt = document.createElement('option');
        opt.value = vp.id;
        opt.textContent = String(index + 1).padStart(2, '0');
        opt.className = 'bg-neutral-950 text-white';
        pageSelect.appendChild(opt);
      });
    }
    
    const totalPagesLabel = document.getElementById('edit-total-pages-label') as HTMLElement;
    if (totalPagesLabel) {
      totalPagesLabel.textContent = `OF ${String(editablePages.length).padStart(2, '0')}`;
    }
    
    sessionEditablePages = editablePages;
    
    // Load the selected page
    await loadPageInSession(pageId);
    
    // Show modal
    const editModal = document.getElementById('edit-modal') as HTMLElement;
    if (editModal) {
      editModal.classList.remove('hidden');
      editModal.classList.add('flex');
    }
  }

  async function openGlobalEditModal() {
    // Find all editable pages in visual order
    const editablePages = pageOrder
      .map(idx => virtualPages[idx])
      .filter(vp => {
        const ext = vp.fileName.split('.').pop()?.toLowerCase() || '';
        return ['pdf', 'pptx', 'docx'].includes(ext);
      });
      
    if (editablePages.length === 0) return;
    
    // Setup temporary session edits starting with the current state of pageEdits
    tempSessionEdits = JSON.parse(JSON.stringify(pageEdits));
    
    // Setup select options
    const pageSelect = document.getElementById('edit-page-select') as HTMLSelectElement;
    if (pageSelect) {
      pageSelect.innerHTML = '';
      editablePages.forEach((vp, index) => {
        const opt = document.createElement('option');
        opt.value = vp.id;
        opt.textContent = String(index + 1).padStart(2, '0');
        opt.className = 'bg-neutral-950 text-white';
        pageSelect.appendChild(opt);
      });
    }
    
    const totalPagesLabel = document.getElementById('edit-total-pages-label') as HTMLElement;
    if (totalPagesLabel) {
      totalPagesLabel.textContent = `OF ${String(editablePages.length).padStart(2, '0')}`;
    }
    
    sessionEditablePages = editablePages;
    
    // Load the first page
    await loadPageInSession(editablePages[0].id);
    
    // Show modal
    const editModal = document.getElementById('edit-modal') as HTMLElement;
    if (editModal) {
      editModal.classList.remove('hidden');
      editModal.classList.add('flex');
    }
  }

  async function loadPageInSession(pageId: string) {
    // Save current active page's text modifications into tempSessionEdits
    if (currentEditingPageId && currentEditingPageId !== pageId) {
      tempSessionEdits[currentEditingPageId] = {
        items: tempModalEdits,
        textColor: modalTextColor
      };
    }
    
    undoStack = [];
    updateUndoBtnState();
    
    currentEditingPageId = pageId;
    const vp = virtualPages.find(p => p.id === pageId);
    if (!vp) return;
    
    // Update dropdown value
    const pageSelect = document.getElementById('edit-page-select') as HTMLSelectElement;
    if (pageSelect) {
      pageSelect.value = pageId;
    }
    
    // Update title
    const titleEl = document.getElementById('edit-modal-title') as HTMLElement;
    if (titleEl) titleEl.textContent = `${vp.fileName.toUpperCase()}`;
    
    // Load color edits for this page from tempSessionEdits
    const edits = tempSessionEdits[pageId] || { items: [], textColor: 'black' };
    
    // Update color buttons UI state
    const setModalTextColor = (window as any).setModalTextColor;
    if (typeof setModalTextColor === 'function') setModalTextColor(edits.textColor);
    
    setActiveSegment(null); // Clear active segment style panel selection!
    
    // Update prev/next button enabled states
    const curIndex = sessionEditablePages.findIndex(p => p.id === pageId);
    const prevBtn = document.getElementById('edit-prev-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('edit-next-btn') as HTMLButtonElement;
    
    if (prevBtn) prevBtn.disabled = curIndex === 0;
    if (nextBtn) nextBtn.disabled = curIndex === sessionEditablePages.length - 1;
    
    // Render high-res edit canvas & overlays
    await renderEditCanvasSession(pageId);
  }

  async function renderEditCanvasSession(pageId: string) {
    const vp = virtualPages.find(p => p.id === pageId);
    if (!vp) return;
    
    const pdfJsDoc = loadedPdfJsDocs[vp.fileIndex];
    const page = await pdfJsDoc.getPage(vp.pageIndex + 1);
    
    const canvas = document.getElementById('edit-page-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    
    const context = canvas.getContext('2d');
    if (!context) return;
    
    const parentContainer = canvas.parentElement?.parentElement;
    const parentWidth = parentContainer && parentContainer.clientWidth > 0 ? parentContainer.clientWidth - 32 : 500;
    const parentHeight = parentContainer && parentContainer.clientHeight > 0 ? parentContainer.clientHeight - 32 : 550;
    const isMobile = window.innerWidth < 1024;
    
    const originalViewport = page.getViewport({ scale: 1 });
    const ratio = originalViewport.width / originalViewport.height;
    
    let scale = 1;
    if (isMobile) {
      // On mobile, fit preview within fixed height container
      const maxPreviewHeight = parentContainer?.clientHeight || 120;
      scale = Math.min(maxPreviewHeight / originalViewport.height, (parentContainer?.clientWidth || 300) / originalViewport.width);
      scale = Math.min(scale, 0.5); // cap at 0.5 on mobile to keep it compact
    } else {
      if (parentWidth / parentHeight > ratio) {
        scale = parentHeight / originalViewport.height;
      } else {
        scale = parentWidth / originalViewport.width;
      }
    }
    const viewport = page.getViewport({ scale });
    currentViewport = viewport;
    
    canvas.width = viewport.width;
    canvas.height = viewport.height;
    
    const container = document.getElementById('edit-canvas-container') as HTMLElement;
    if (container) {
      container.style.width = viewport.width + 'px';
      container.style.height = viewport.height + 'px';
    }
    
    if (!cleanOffscreenCanvas) {
      cleanOffscreenCanvas = document.createElement('canvas');
    }
    cleanOffscreenCanvas.width = viewport.width;
    cleanOffscreenCanvas.height = viewport.height;
    const offscreenContext = cleanOffscreenCanvas.getContext('2d');
    if (!offscreenContext) return;
    
    if (activeEditCanvasRenderTask) {
      try {
        activeEditCanvasRenderTask.cancel();
      } catch (e) {}
    }

    const renderContext = {
      canvasContext: offscreenContext,
      viewport: viewport
    };
    
    try {
      const renderTask = page.render(renderContext);
      activeEditCanvasRenderTask = renderTask;
      await renderTask.promise;
      if (activeEditCanvasRenderTask === renderTask) {
        activeEditCanvasRenderTask = null;
      }
      
      context.clearRect(0, 0, canvas.width, canvas.height);
      context.drawImage(cleanOffscreenCanvas, 0, 0);
      
      const edits = tempSessionEdits[pageId] || { items: [], textColor: 'black' };
      
      await renderTextOverlays(page, viewport, pageId, edits, canvas);
      
      if (tempModalEdits.length > 0) {
        drawEditsOnCanvas(canvas, viewport, { items: tempModalEdits, textColor: modalTextColor });
      }
    } catch (err: any) {
      if (err && err.name === 'RenderingCancelledException') {
        return;
      }
      console.error(err);
    }
  }

  function setupSessionPageSelector() {
    const pageSelect = document.getElementById('edit-page-select') as HTMLSelectElement;
    const prevBtn = document.getElementById('edit-prev-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('edit-next-btn') as HTMLButtonElement;
    
    if (pageSelect) {
      pageSelect.addEventListener('change', () => {
        loadPageInSession(pageSelect.value);
      });
    }
    
    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        const curIndex = sessionEditablePages.findIndex(p => p.id === currentEditingPageId);
        if (curIndex > 0) {
          loadPageInSession(sessionEditablePages[curIndex - 1].id);
        }
      });
    }
    
    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        const curIndex = sessionEditablePages.findIndex(p => p.id === currentEditingPageId);
        if (curIndex < sessionEditablePages.length - 1) {
          loadPageInSession(sessionEditablePages[curIndex + 1].id);
        }
      });
    }
  }

  // Mobile keyboard handling: adjust edit modal height on visual viewport change
  if (window.visualViewport) {
    let keyboardScrollTimeout: number;
    window.visualViewport.addEventListener('resize', () => {
      const editModal = document.getElementById('edit-modal') as HTMLElement;
      if (!editModal || editModal.classList.contains('hidden')) return;
      const vh = window.visualViewport?.height || window.innerHeight;
      const scrollable = editModal.querySelector('.relative.z-10') as HTMLElement;
      if (scrollable) {
        scrollable.style.minHeight = `${vh}px`;
      }
      // If keyboard is likely open (visual viewport shrunk), scroll active textarea into view
      if (window.visualViewport && window.visualViewport.height < window.innerHeight * 0.8) {
        clearTimeout(keyboardScrollTimeout);
        keyboardScrollTimeout = window.setTimeout(() => {
          const activeEl = document.activeElement as HTMLElement;
          if (activeEl && (activeEl.tagName === 'TEXTAREA' || activeEl.tagName === 'INPUT')) {
            activeEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        }, 300);
      }
    });
  }

  let previewVisible = false;

  function updatePreviewCanvas() {
    const overlay = document.getElementById('preview-overlay') as HTMLElement;
    if (!overlay || overlay.classList.contains('hidden')) return;
    const canvas = document.getElementById('preview-canvas') as HTMLCanvasElement;
    if (!canvas || !previewBaseCanvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.drawImage(previewBaseCanvas, 0, 0);
    const previewViewport = (window as any).__previewViewport;
    if (previewViewport) {
      drawEditsOnCanvas(canvas, previewViewport, { items: tempModalEdits, textColor: modalTextColor });
    }
  }

  function renderPreviewPage(pageId: string) {
    const canvas = document.getElementById('preview-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const vp = virtualPages.find(p => p.id === pageId);
    if (!vp) return;
    const pdfJsDoc = loadedPdfJsDocs[vp.fileIndex];
    if (!pdfJsDoc) return;
    
    const previewContainer = document.getElementById('preview-content') as HTMLElement;
    if (!previewContainer) return;
    
    // Load current edits into temp if navigating from another page
    if (currentEditingPageId && currentEditingPageId !== pageId) {
      tempSessionEdits[currentEditingPageId] = {
        items: tempModalEdits,
        textColor: modalTextColor
      };
    }
    
    const targetPageId = pageId;
    
    pdfJsDoc.getPage(vp.pageIndex + 1).then((page) => {
      if (targetPageId !== pageId) return; // stale
      
      const dpr = window.devicePixelRatio || 1;
      const containerWidth = previewContainer.clientWidth - 32;
      const containerHeight = previewContainer.clientHeight - 32;
      
      const origViewport = page.getViewport({ scale: 1 });
      const scaleX = containerWidth / origViewport.width;
      const scaleY = containerHeight / origViewport.height;
      const scale = Math.min(scaleX, scaleY) * dpr;
      
      const viewport = page.getViewport({ scale });
      (window as any).__previewViewport = viewport;
      
      canvas.style.width = (viewport.width / dpr) + 'px';
      canvas.style.height = (viewport.height / dpr) + 'px';
      canvas.width = viewport.width;
      canvas.height = viewport.height;
      
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      
      if (!previewBaseCanvas) {
        previewBaseCanvas = document.createElement('canvas');
      }
      previewBaseCanvas.width = viewport.width;
      previewBaseCanvas.height = viewport.height;
      const baseCtx = previewBaseCanvas.getContext('2d');
      if (!baseCtx) return;
      
      const renderContext = { canvasContext: baseCtx, viewport };
      page.render(renderContext).promise.then(() => {
        if (targetPageId !== pageId) return;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.drawImage(previewBaseCanvas!, 0, 0);
        // Use tempModalEdits if viewing same page as editor, else use saved session edits
        const isCurrentPage = pageId === currentEditingPageId;
        const edits = isCurrentPage
          ? { items: tempModalEdits, textColor: modalTextColor }
          : (tempSessionEdits[pageId] || { items: [], textColor: 'black' });
        if (edits.items && edits.items.length > 0) {
          drawEditsOnCanvas(canvas, viewport, edits);
        }
        // Update title
        const titleEl = document.getElementById('preview-title') as HTMLElement;
        const idx = sessionEditablePages.findIndex(p => p.id === pageId);
        if (titleEl && idx >= 0) {
          titleEl.textContent = `PAGE ${idx + 1} OF ${sessionEditablePages.length}`;
        }
        // Update nav buttons
        const prevBtn = document.getElementById('preview-prev-btn') as HTMLButtonElement;
        const nextBtn = document.getElementById('preview-next-btn') as HTMLButtonElement;
        if (prevBtn) prevBtn.disabled = idx <= 0;
        if (nextBtn) nextBtn.disabled = idx >= sessionEditablePages.length - 1;
        previewPageIndex = idx;
      }).catch(() => {});
    });
  }

  function openPreviewOverlay() {
    const overlay = document.getElementById('preview-overlay') as HTMLElement;
    if (!overlay) return;
    overlay.classList.remove('hidden');
    
    // Save current edits to session before rendering any page
    if (currentEditingPageId) {
      tempSessionEdits[currentEditingPageId] = {
        items: tempModalEdits,
        textColor: modalTextColor
      };
    }
    
    renderPreviewPage(currentEditingPageId);
  }

  function closePreviewOverlay() {
    const overlay = document.getElementById('preview-overlay') as HTMLElement;
    const canvas = document.getElementById('preview-canvas') as HTMLCanvasElement;
    if (canvas) {
      canvas.width = 0;
      canvas.height = 0;
    }
    if (previewBaseCanvas) {
      previewBaseCanvas.width = 0;
      previewBaseCanvas.height = 0;
    }
    (window as any).__previewViewport = null;
    if (overlay) overlay.classList.add('hidden');
    // Reload current editing page to restore tempModalEdits from session
    if (currentEditingPageId) {
      const edits = tempSessionEdits[currentEditingPageId];
      if (edits) {
        tempModalEdits = JSON.parse(JSON.stringify(edits.items));
        modalTextColor = edits.textColor;
      }
    }
    // Redraw the editor canvas to reflect the restored edits
    redrawEditCanvas();
  }

  function pushUndoState(editItem: any) {
    undoStack.push({
      editedText: editItem.editedText,
      fontSize: editItem.fontSize,
      isBold: editItem.isBold,
      isItalic: editItem.isItalic,
      isUnderlined: editItem.isUnderlined,
      fontNameMapped: editItem.fontNameMapped,
      index: editItem.index
    });
  }

  function undoLastEdit() {
    if (undoStack.length === 0) return;
    const prev = undoStack.pop();
    const editItem = tempModalEdits.find((e: any) => e.index === prev.index);
    if (!editItem) return;
    Object.assign(editItem, prev);
    editItem._undoSaved = false;
    const textarea = document.querySelector(`textarea[data-index="${prev.index}"]`) as HTMLTextAreaElement;
    if (textarea) textarea.value = editItem.editedText;
    const listContainer = document.getElementById('edit-text-list') as HTMLElement;
    const listItem = listContainer?.querySelector(`textarea[data-index="${prev.index}"]`)?.closest('div') as HTMLElement;
    if (listItem) markAsModified(listItem, editItem);
    setActiveSegment(prev.index, editItem);
    redrawEditCanvas();
    updateUndoBtnState();
  }

  function updateUndoBtnState() {
    const undoBtn = document.getElementById('edit-undo-btn') as HTMLButtonElement;
    if (undoBtn) undoBtn.disabled = undoStack.length === 0;
  }

  function closeEditModal() {
    const editModal = document.getElementById('edit-modal') as HTMLElement;
    if (editModal) {
      editModal.classList.add('hidden');
      editModal.classList.remove('flex');
    }
    currentEditingPageId = '';
    tempModalEdits = [];
    tempSessionEdits = {};
    sessionEditablePages = [];
    undoStack = [];
  }

  function saveEditChanges() {
    // Sync editItem.editedText from textarea DOM values before saving.
    // On mobile, input events may not fire reliably with virtual keyboards,
    // so reading directly from the DOM ensures we capture the latest text.
    const listContainer = document.getElementById('edit-text-list') as HTMLElement;
    if (listContainer) {
      const textareas = listContainer.querySelectorAll('textarea');
      textareas.forEach((ta: HTMLTextAreaElement) => {
        const idx = parseInt(ta.dataset.index || '', 10);
        if (!isNaN(idx)) {
          const editItem = tempModalEdits.find((e: any) => e.index === idx);
          if (editItem && editItem.editedText !== ta.value) {
            if (!editItem._undoSaved) {
              undoStack.push(JSON.parse(JSON.stringify(editItem)));
              editItem._undoSaved = true;
            }
            editItem.editedText = ta.value;
          }
        }
      });
    }
    
    // Cache current active page modifications first
    if (currentEditingPageId) {
      tempSessionEdits[currentEditingPageId] = {
        items: tempModalEdits,
        textColor: modalTextColor
      };
    }
    
    // Commit the session edits to the global pageEdits dictionary via deep copy
    // to avoid reference sharing issues that break subsequent saves
    pageEdits = JSON.parse(JSON.stringify(tempSessionEdits));
    
    // Reset undo stack since edits are now committed
    undoStack = [];
    updateUndoBtnState();
    
    // Refresh thumbnail grid to persist edits visually
    renderPagesGrid();
    
    // Redraw the editor canvas to confirm applied state
    redrawEditCanvas();
    
    // Show saved feedback on the button
    const saveBtn = document.getElementById('edit-save-btn') as HTMLButtonElement;
    if (saveBtn) {
      const originalText = saveBtn.textContent || 'Apply Changes';
      saveBtn.textContent = 'SAVED';
      saveBtn.classList.add('ring-2', 'ring-primary', 'ring-offset-2', 'ring-offset-canvas');
      setTimeout(() => {
        saveBtn.textContent = originalText;
        saveBtn.classList.remove('ring-2', 'ring-primary', 'ring-offset-2', 'ring-offset-canvas');
      }, 1500);
    }
  }

  function togglePageSelection(pageId: string) {
    if (selectedPages.has(pageId)) {
      selectedPages.delete(pageId);
      setCardSelectedVisual(pageId, false);
    } else {
      selectedPages.add(pageId);
      setCardSelectedVisual(pageId, true);
    }
    
    // De-synchronize range input
    rangeInput.value = '';
    updateStickyFooter();
  }

  function setCardSelectedVisual(pageId: string, isSelected: boolean) {
    const card = document.getElementById(`page-card-${pageId}`);
    if (!card) return;

    const badge = card.querySelector('.card-check-badge') as HTMLElement;
    const checkIcon = card.querySelector('.check-icon') as HTMLElement;

    if (isSelected) {
      card.classList.remove('border-neutral-800', 'hover:border-neutral-700', 'bg-canvas-soft/20');
      card.classList.add('border-primary', 'bg-primary/5', 'shadow-[0_0_15px_rgba(159,232,112,0.1)]');
      
      badge.classList.remove('border-neutral-800', 'bg-canvas-soft/80');
      badge.classList.add('bg-primary', 'border-primary');
      checkIcon.classList.remove('hidden');
    } else {
      card.classList.remove('border-primary', 'bg-primary/5', 'shadow-[0_0_15px_rgba(159,232,112,0.1)]');
      card.classList.add('border-neutral-800', 'bg-canvas-soft/20');
      
      badge.classList.remove('bg-primary', 'border-primary');
      badge.classList.add('border-neutral-800', 'bg-canvas-soft/80');
      checkIcon.classList.add('hidden');
    }
  }

  // Quick Action Selection Helpers
  function selectAll() {
    selectedPages.clear();
    virtualPages.forEach((vp) => {
      selectedPages.add(vp.id);
      setCardSelectedVisual(vp.id, true);
    });
    rangeInput.value = '';
    updateStickyFooter();
  }

  // Quick Action Clear Selection Helpers
  function clearSelection() {
    selectedPages.clear();
    virtualPages.forEach((vp) => {
      setCardSelectedVisual(vp.id, false);
    });
    rangeInput.value = '';
    updateStickyFooter();
  }

  function invertSelection() {
    virtualPages.forEach((vp) => {
      if (selectedPages.has(vp.id)) {
        selectedPages.delete(vp.id);
        setCardSelectedVisual(vp.id, false);
      } else {
        selectedPages.add(vp.id);
        setCardSelectedVisual(vp.id, true);
      }
    });
    rangeInput.value = '';
    updateStickyFooter();
  }

  // Parse Range text fields e.g., '1, 3, 5-8' based on visual order
  function handleRangeInput(e: Event) {
    const value = (e.target as HTMLInputElement).value;
    
    // Clear visual styles
    virtualPages.forEach((vp) => {
      setCardSelectedVisual(vp.id, false);
    });
    selectedPages.clear();

    if (!value.trim()) {
      updateStickyFooter();
      return;
    }

    const totalVirtualPages = virtualPages.length;
    const parts = value.split(',');
    for (const part of parts) {
      const trimmed = part.trim();
      if (!trimmed) continue;

      if (/^\d+$/.test(trimmed)) {
        const visualNum = parseInt(trimmed, 10);
        if (visualNum >= 1 && visualNum <= totalVirtualPages) {
          const virtualIndex = pageOrder[visualNum - 1];
          const vp = virtualPages[virtualIndex];
          selectedPages.add(vp.id);
          setCardSelectedVisual(vp.id, true);
        }
      } else if (/^\d+-\d+$/.test(trimmed)) {
        const [startStr, endStr] = trimmed.split('-');
        let start = parseInt(startStr, 10);
        let end = parseInt(endStr, 10);
        
        if (isNaN(start) || isNaN(end)) continue;
        
        if (start > end) {
          [start, end] = [end, start];
        }

        for (let p = start; p <= end; p++) {
          if (p >= 1 && p <= totalVirtualPages) {
            const virtualIndex = pageOrder[p - 1];
            const vp = virtualPages[virtualIndex];
            selectedPages.add(vp.id);
            setCardSelectedVisual(vp.id, true);
          }
        }
      }
    }

    updateStickyFooter();
  }

  // Real-Time page content search parsing across all active files
  function handleSearchInput(e: Event) {
    const query = (e.target as HTMLInputElement).value.trim().toLowerCase();
    
    if (!query) {
      virtualPages.forEach((vp) => {
        const card = document.getElementById(`page-card-${vp.id}`);
        if (card) card.classList.remove('opacity-25');
      });
      searchSelectBtn.classList.add('hidden');
      return;
    }

    let matchCount = 0;
    const matchingIds: string[] = [];

    // Filter virtual pages text
    virtualPages.forEach((vp) => {
      const isMatch = vp.text.includes(query);
      const card = document.getElementById(`page-card-${vp.id}`);

      if (card) {
        if (isMatch) {
          card.classList.remove('opacity-25');
          matchCount++;
          matchingIds.push(vp.id);
        } else {
          card.classList.add('opacity-25');
        }
      }
    });

    if (matchCount > 0) {
      searchSelectBtn.textContent = `Select ${matchCount}`;
      searchSelectBtn.classList.remove('hidden');
      
      // Select search matches handler
      searchSelectBtn.onclick = () => {
        matchingIds.forEach((id) => {
          selectedPages.add(id);
          setCardSelectedVisual(id, true);
        });
        updateStickyFooter();
        // Clear search input
        searchInput.value = '';
        handleSearchInput({ target: searchInput } as any);
      };
    } else {
      searchSelectBtn.classList.add('hidden');
    }
  }

  // Footer visual logic
  function updateStickyFooter() {
    const count = selectedPages.size;
    selectedCountLabel.textContent = count.toString();

    if (count > 0) {
      stickyFooter.classList.remove('translate-y-full');
      extractBtn.disabled = false;
      extractBtn.classList.remove('opacity-55', 'cursor-not-allowed');
    } else {
      stickyFooter.classList.add('translate-y-full');
      extractBtn.disabled = true;
      extractBtn.classList.add('opacity-55', 'cursor-not-allowed');
    }
  }

  // Client-Side compilation & merging of multiple PDF pages
  async function executeExtraction() {
    if (selectedPages.size === 0 || loadedPdfDocs.length === 0 || loadedFiles.length === 0) return;

    // Show Loader State
    extractBtn.disabled = true;
    extractBtn.textContent = 'PROCESSING…';
    compilingLoader.classList.remove('hidden');
    compilingLoader.classList.add('flex');

    // Run compiler in next tick to allow DOM spinner to render
    setTimeout(async () => {
      try {
        const newPdfDoc = await PDFDocument.create();
        
        // Find which pages in pageOrder visual array are selected, preserving rearranged visual order
        const selectedVirtualPages = pageOrder
          .map(idx => virtualPages[idx])
          .filter(vp => selectedPages.has(vp.id));
        
        // Copy and append pages from original document references
        for (const vp of selectedVirtualPages) {
          const originalLibDoc = loadedPdfDocs[vp.fileIndex];
          const [copiedPage] = await newPdfDoc.copyPages(originalLibDoc, [vp.pageIndex]);
          
          // Apply user edits using pdf-lib
          if (pageEdits[vp.id]) {
            const edits = pageEdits[vp.id];
            for (const editItem of edits.items) {
              const isModified = editItem.editedText !== editItem.originalText || 
                                 editItem.fontSize !== (editItem.originalFontSize || editItem.fontSize) || 
                                 editItem.isBold !== (editItem.originalIsBold || false) || 
                                 editItem.isItalic !== (editItem.originalIsItalic || false) || 
                                 editItem.isUnderlined;
              if (isModified) {
                // Erase old text block using the dynamically sampled background color
                const bg = editItem.bgColor || { r: 255, g: 255, b: 255 };
                const fillColor = rgb(bg.r / 255, bg.g / 255, bg.b / 255);
                const origSize = editItem.originalFontSize || editItem.fontSize;
                copiedPage.drawRectangle({
                  x: editItem.x,
                  y: editItem.y - origSize * 0.35,
                  width: editItem.width * 1.05,
                  height: origSize * 1.35,
                  color: fillColor,
                });
                
                // Embed matching font family
                const fontToUse = await newPdfDoc.embedFont(editItem.fontNameMapped);
                
                // Set text color
                let textColor = rgb(0, 0, 0);
                if (edits.textColor === 'white') textColor = rgb(1, 1, 1);
                else if (edits.textColor === 'red') textColor = rgb(0.8, 0.1, 0.1);
                else if (edits.textColor === 'blue') textColor = rgb(0.1, 0.1, 0.8);
                
                // Write new text layer
                const cleanText = sanitizeTextForWinAnsi(editItem.editedText);
                copiedPage.drawText(cleanText, {
                  x: editItem.x,
                  y: editItem.y,
                  size: editItem.fontSize,
                  font: fontToUse,
                  color: textColor,
                });

                // Draw underline if set
                if (editItem.isUnderlined) {
                  const textWidth = fontToUse.widthOfTextAtSize(cleanText, editItem.fontSize);
                  copiedPage.drawLine({
                    start: { x: editItem.x, y: editItem.y - editItem.fontSize * 0.05 },
                    end: { x: editItem.x + textWidth, y: editItem.y - editItem.fontSize * 0.05 },
                    thickness: Math.max(1, editItem.fontSize * 0.06),
                    color: textColor,
                  });
                }
              }
            }
          }
          
          newPdfDoc.addPage(copiedPage);
        }
        
        // Save bytes
        const newPdfBytes = await newPdfDoc.save();

        // Download locally in browser
        const blob = new Blob([newPdfBytes], { type: 'application/pdf' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        
        a.href = url;
        let originalBase = 'pageslice_compiled';
        if (loadedFiles.length > 0) {
          originalBase = loadedFiles[0].name.replace(/\.[^/.]+$/, "");
          if (loadedFiles.length > 1) {
            originalBase += `_and_${loadedFiles.length - 1}_other_files`;
          }
        }
        a.download = `${originalBase}_extracted.pdf`;
        
        document.body.appendChild(a);
        a.click();
        
        // Cleanup resources
        setTimeout(() => {
          document.body.removeChild(a);
          URL.revokeObjectURL(url);
        }, 100);

      } catch (err) {
        console.error(err);
        showError('COMPILE ERROR: Page extraction operation failed. Check that pages exist.');
      } finally {
        // Reset states
        extractBtn.disabled = false;
        extractBtn.textContent = 'Extract Selected Pages';
        compilingLoader.classList.remove('flex');
        compilingLoader.classList.add('hidden');
      }
    }, 50);
  }

  // App Reset Logic
  function resetApp() {
    resetState();
    
    // Toggle screens
    dashboardSection.classList.add('hidden');
    dropzoneSection.classList.remove('hidden');
    pdfInput.value = '';
    addFilesInput.value = '';
  }

  function resetState() {
    loadedFiles = [];
    loadedPdfDocs = [];
    loadedPdfJsDocs = [];
    virtualPages = [];
    pageOrder = [];
    selectedPages.clear();
    pageEdits = {};
    pendingFile = null;
    pendingFilesList = null;
    filePasswords = {};
    pendingIsAppend = false;
    rangeInput.value = '';
    searchInput.value = '';
    searchSelectBtn.classList.add('hidden');
    updateStickyFooter();
    hideDecryptionPrompt();

    // Reset Edit Pages button visibility
    const editPagesBtn = document.getElementById('edit-pages-btn') as HTMLButtonElement;
    if (editPagesBtn) {
      editPagesBtn.classList.add('hidden');
    }
  }

  // Utility helpers
  function showError(msg: string) {
    errorMessage.textContent = msg;
    errorBanner.classList.remove('hidden');
    errorBanner.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    
    if (pendingFile) {
      decryptError.classList.remove('hidden');
    }
  }

  // Hide errors
  function hideError() {
    errorBanner.classList.add('hidden');
    decryptError.classList.add('hidden');
  }

  function formatBytes(bytes: number, decimals = 2) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const dm = decimals < 0 ? 0 : decimals;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
  }
</script>

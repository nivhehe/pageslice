  // DOCX to PDF converter client-side using XML parsing via JSZip
  async function convertDocxToPdf(arrayBuffer: ArrayBuffer): Promise<ArrayBuffer> {
    // @ts-ignore
    const JSZip = window.JSZip;
    const zip = await JSZip.loadAsync(arrayBuffer);
    const docXml = await zip.file("word/document.xml").async("string");
    
    const parser = new DOMParser();
    const xmlDoc = parser.parseFromString(docXml, "text/xml");
    const paragraphs = xmlDoc.getElementsByTagName("w:p");
    
    const lines: string[] = [];
    for (let i = 0; i < paragraphs.length; i++) {
      const p = paragraphs[i];
      const text = p.textContent || '';
      
      const words = text.split(/\s+/);
      let currentLine = '';
      for (const word of words) {
        if ((currentLine + ' ' + word).length > 75) {
          lines.push(currentLine.trim());
          currentLine = word;
        } else {
          currentLine = currentLine ? currentLine + ' ' + word : word;
        }
      }
      if (currentLine) {
        lines.push(currentLine.trim());
      }
      lines.push('');
    }

    const newPdfDoc = await PDFDocument.create();
    const font = await newPdfDoc.embedFont(StandardFonts.Helvetica);
    const linesPerPage = 35;
    const pageCount = Math.ceil(lines.length / linesPerPage) || 1;

    for (let p = 0; p < pageCount; p++) {
      const page = newPdfDoc.addPage([612, 792]);
      const startIndex = p * linesPerPage;
      const pageLines = lines.slice(startIndex, startIndex + linesPerPage);
      
      pageLines.forEach((line, index) => {
        if (!line.trim()) return;
        page.drawText(sanitizeTextForWinAnsi(line), {
          x: 50,
          y: 730 - index * 18,
          size: 10.5,
          font: font,
          color: { type: 'RGB', red: 0.08, green: 0.09, blue: 0.08 }
        });
      });
    }

    return await newPdfDoc.save();
  }

  // PPTX to PDF converter client-side using slides XML parsing via JSZip
  async function convertPptxToPdf(arrayBuffer: ArrayBuffer): Promise<ArrayBuffer> {
    // @ts-ignore
    const JSZip = window.JSZip;
    const zip = await JSZip.loadAsync(arrayBuffer);
    
    const slideFiles = Object.keys(zip.files).filter(name => name.startsWith("ppt/slides/slide") && name.endsWith(".xml"));
    slideFiles.sort((a, b) => {
      const numA = parseInt(a.replace(/[^0-9]/g, ""), 10);
      const numB = parseInt(b.replace(/[^0-9]/g, ""), 10);
      return numA - numB;
    });

    const newPdfDoc = await PDFDocument.create();
    const font = await newPdfDoc.embedFont(StandardFonts.Helvetica);

    if (slideFiles.length === 0) {
      const page = newPdfDoc.addPage([792, 612]);
      page.drawText("EMPTY PRESENTATION SLIDES", { x: 100, y: 300, size: 24, font });
    }

    for (const slideFile of slideFiles) {
      const slideXml = await zip.file(slideFile).async("string");
      const parser = new DOMParser();
      const xmlDoc = parser.parseFromString(slideXml, "text/xml");
      
      const textElements = xmlDoc.getElementsByTagName("a:t");
      let slideText = "";
      for (let i = 0; i < textElements.length; i++) {
        slideText += textElements[i].textContent + " ";
      }

      const page = newPdfDoc.addPage([792, 612]);
      page.drawRectangle({
        x: 20,
        y: 20,
        width: 752,
        height: 572,
        borderWidth: 1,
        borderColor: { type: 'RGB', red: 0.85, green: 0.85, blue: 0.85 },
        color: { type: 'RGB', red: 0.98, green: 0.98, blue: 0.98 }
      });

      const words = slideText.trim().split(/\s+/);
      const lines: string[] = [];
      let currentLine = '';
      for (const word of words) {
        if ((currentLine + ' ' + word).length > 90) {
          lines.push(currentLine.trim());
          currentLine = word;
        } else {
          currentLine = currentLine ? currentLine + ' ' + word : word;
        }
      }
      if (currentLine) {
        lines.push(currentLine.trim());
      }

      lines.slice(0, 22).forEach((line, index) => {
        page.drawText(sanitizeTextForWinAnsi(line), {
          x: 50,
          y: 530 - index * 22,
          size: 12.5,
          font: font,
          color: { type: 'RGB', red: 0.1, green: 0.1, blue: 0.1 }
        });
      });
    }

    return await newPdfDoc.save();
  }

  // Image to PDF compilation client-side
  async function convertImageToPdf(arrayBuffer: ArrayBuffer, fileName: string): Promise<ArrayBuffer> {
    const newPdfDoc = await PDFDocument.create();
    let image;
    
    if (fileName.toLowerCase().endsWith('.png')) {
      image = await newPdfDoc.embedPng(arrayBuffer);
    } else {
      image = await newPdfDoc.embedJpg(arrayBuffer);
    }

    const { width, height } = image.scale(0.8);
    const page = newPdfDoc.addPage([width, height]);
    
    page.drawImage(image, {
      x: 0,
      y: 0,
      width,
      height
    });

    return await newPdfDoc.save();
  }

  // Core Processing Flow for Multiple Files
  async function processFiles(files: FileList | File[], append = false) {
    // Show temporary spinner in button
    const activeBtn = append ? addFilesBtn : browseBtn;
    if (activeBtn) {
      activeBtn.textContent = 'LOADING…';
      activeBtn.disabled = true;
    }
    hideError();

    if (!append) {
      // Reset states
      loadedFiles = [];
      loadedPdfDocs = [];
      loadedPdfJsDocs = [];
      virtualPages = [];
      pageOrder = [];
      selectedPages.clear();
      filePasswords = {};
    }

    const newFilesArray = Array.from(files);
    const startIndex = loadedFiles.length;
    
    // Add to loaded files list
    if (append) {
      loadedFiles = [...loadedFiles, ...newFilesArray];
    } else {
      loadedFiles = newFilesArray;
    }

    let totalBytes = loadedFiles.reduce((acc, f) => acc + f.size, 0);

    try {
      // Process new files sequentially
      for (let i = 0; i < newFilesArray.length; i++) {
        const file = newFilesArray[i];
        const f = startIndex + i; // absolute file index
        
        if (!/\.(pdf|docx|pptx|png|jpe?g)$/i.test(file.name)) {
          showError(`FILE FORMAT ERROR: "${file.name}" is not supported. Use PDF, DOCX, PPTX, or Images.`);
          return;
        }

        let arrayBuffer = await file.arrayBuffer();

        // Perform client-side conversions if not PDF
        if (file.name.toLowerCase().endsWith('.docx')) {
          arrayBuffer = await convertDocxToPdf(arrayBuffer);
        } else if (file.name.toLowerCase().endsWith('.pptx')) {
          arrayBuffer = await convertPptxToPdf(arrayBuffer);
        } else if (/\.(png|jpe?g)$/i.test(file.name)) {
          arrayBuffer = await convertImageToPdf(arrayBuffer, file.name);
        }

        // Load PDF via pdf-lib for compilation (slice buffer to avoid detachment)
        const libBuffer = arrayBuffer.slice(0);
        const filePassword = filePasswords[f] || '';
        let pdfLibDoc;
        try {
          pdfLibDoc = await PDFDocument.load(libBuffer, { 
            updateMetadata: false,
            password: filePassword
          });
        } catch (libErr: any) {
          if (libErr.message.includes('Password') || libErr.message.includes('encrypted') || libErr.message.includes('decrypt')) {
            showDecryptionPromptForFile(file, newFilesArray, f, append);
            return;
          }
          throw libErr;
        }

        const filePagesCount = pdfLibDoc.getPageCount();
        if (filePagesCount === 0) continue;

        // Load PDF via PDF.js for rendering thumbnails
        // @ts-ignore
        const pdfjsLib = window.pdfjsLib;
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
        const jsDocBuffer = arrayBuffer.slice(0);
        
        let pdfJsDoc;
        try {
          const loadingTask = pdfjsLib.getDocument({ 
            data: jsDocBuffer,
            password: filePassword
          });
          pdfJsDoc = await loadingTask.promise;
        } catch (jsErr: any) {
          if (jsErr.name === 'PasswordException') {
            showDecryptionPromptForFile(file, newFilesArray, f, append);
            return;
          }
          throw jsErr;
        }

        loadedPdfDocs[f] = pdfLibDoc;
        loadedPdfJsDocs[f] = pdfJsDoc;

        // Extract text and build VirtualPage metadata
        const oldVirtualPagesLength = virtualPages.length;
        const newVirtualPages: VirtualPage[] = [];
        for (let p = 0; p < filePagesCount; p++) {
          let textStr = '';
          try {
            const page = await pdfJsDoc.getPage(p + 1);
            const textObj = await page.getTextContent();
            textStr = textObj.items.filter((item: any) => item && typeof item.str === 'string').map((item: any) => item.str).join(' ');
          } catch (err) {
            console.error(`Error extracting page text:`, err);
          }

          const pageId = `${f}-${p}`;
          newVirtualPages.push({
            id: pageId,
            fileIndex: f,
            pageIndex: p,
            fileName: file.name,
            text: textStr.toLowerCase()
          });
        }

        virtualPages = [...virtualPages, ...newVirtualPages];
        
        // Append new page indices to the visual order
        const newPageIndices = Array.from(
          { length: newVirtualPages.length }, 
          (_, idx) => oldVirtualPagesLength + idx
        );
        pageOrder = [...pageOrder, ...newPageIndices];
      }

      const totalVirtualPages = virtualPages.length;
      if (totalVirtualPages === 0) {
        throw new Error('No pages found in uploaded files.');
      }

      // Update Metadata readout UI
      let activeFileNameText = '';
      if (loadedFiles.length === 1) {
        activeFileNameText = loadedFiles[0].name.toUpperCase();
      } else {
        const firstFileBase = loadedFiles[0].name.replace(/\.[^/.]+$/, "").toUpperCase();
        activeFileNameText = `${firstFileBase} + ${loadedFiles.length - 1} OTHER FILE${loadedFiles.length > 2 ? 'S' : ''}`;
      }

      metaFilename.textContent = activeFileNameText;
      metaFilesize.textContent = formatBytes(totalBytes);
      metaTotalPages.textContent = `${totalVirtualPages} Page${totalVirtualPages > 1 ? 's' : ''}`;

      // Reset control fields if not appending
      if (!append) {
        rangeInput.value = '';
        searchInput.value = '';
        searchSelectBtn.classList.add('hidden');
      }

      // Populate interactive grid
      renderPagesGrid();
      updateStickyFooter();

      // View Transitions / Show dashboard
      dropzoneSection.classList.add('hidden');
      dashboardSection.classList.remove('hidden');

      // Show/hide Edit Pages button based on whether document files exist
      const hasEditableFiles = virtualPages.some(vp => {
        const ext = vp.fileName.split('.').pop()?.toLowerCase() || '';
        return ['pdf', 'pptx', 'docx'].includes(ext);
      });
      
      const editPagesBtn = document.getElementById('edit-pages-btn') as HTMLButtonElement;
      if (editPagesBtn) {
        if (hasEditableFiles) {
          editPagesBtn.classList.remove('hidden');
        } else {
          editPagesBtn.classList.add('hidden');
        }
      }

      // Show toast notification to drag-reorder pages
      showToast();
    } catch (err) {
      console.error(err);
      showError('PARSING ERROR: Unable to read file data locally. Document may be encrypted or corrupted.');
      resetState();
    } finally {
      if (activeBtn) {
        activeBtn.textContent = append ? 'Add Files' : 'Browse Files';
        activeBtn.disabled = false;
      }
    }
  }

